-- | Test complete syndication workflow: CommitToSyndicate -> FinalizeSyndicate -> Add/Remove Participants
testCompleteSyndicationWorkflow : Script ()
testCompleteSyndicationWorkflow = do
  parties@Test_Parties{..} <- test_setup
  leadArranger <- allocateParty "WorkflowArranger"
  lender1 <- allocateParty "WorkflowLender1"
  lender2 <- allocateParty "WorkflowLender2"
  lender3 <- allocateParty "WorkflowLender3"
  
  now <- getTime
  
  -- Create syndicate formation
  formationCid <- submit leadArranger do
    createCmd SyndicateFormation with
      formationId = "SYN-WORKFLOW"
      borrower = alice
      leadArranger
      rfqId = "RFQ-WORKFLOW"
      targetAmount = 1000000.0
      commitments = []
      totalCommitted = 0.0
      arrangementFee = 20000.0
      formationDeadline = addRelTime now (days 14)
      status = FormationOpen
  
  -- Test CommitToSyndicate (multiple lenders)
  formationCid <- submit lender1 do
    exerciseCmd formationCid CommitToSyndicate with
      lender = lender1
      commitmentAmount = 400000.0
      profile = Types.LenderProfile with
        lender = lender1
        category = Tier1Bank
        rating = AAA
        totalCapacity = 5000000.0
        availableCapacity = 2000000.0
        activeLoans = 15
        defaultRate = 0.01
        averageInterestRate = 0.07
        geographicFocus = ["Global"]
      role = Participant
  
  formationCid <- submit lender2 do
    exerciseCmd formationCid CommitToSyndicate with
      lender = lender2
      commitmentAmount = 600000.0
      profile = Types.LenderProfile with
        lender = lender2
        category = Tier1Bank
        rating = AA
        totalCapacity = 8000000.0
        availableCapacity = 3000000.0
        activeLoans = 25
        defaultRate = 0.015
        averageInterestRate = 0.075
        geographicFocus = ["Global"]
      role = Participant
  
  -- Test FinalizeSyndicate
  syndicatedLoanCid <- submitMulti [alice, leadArranger] [] do
    exerciseCmd formationCid FinalizeSyndicate with
      interestRateStructure = InterestRateStructure with
        rateType = Fixed
        baseRate = None
        margin = 0.0
        fixedRate = Some 0.08
        floorRate = None
        capRate = None
        resetFrequency = None
      repaymentSchedule = RepaymentSchedule with
        frequency = Quarterly
        numberOfPayments = 12
        gracePeriodDays = 5
        lateFeeRate = 0.001
        earlyRepaymentTerms = EarlyRepaymentTerms with
          allowed = True
          penaltyRate = 0.02
          noticePeriodDays = 10
          minimumHoldPeriod = Some (days 90)
        amortizationType = FullyAmortizing
      collateralAssets = []
      covenants = []
      loanDuration = days 365
  
  -- Test AddSyndicateParticipant
  syndicatedLoanCid <- submitMulti [alice, leadArranger] [] do
    exerciseCmd syndicatedLoanCid AddSyndicateParticipant with
      newParticipant = Types.SyndicateParticipant with
        lender = lender3
        lenderProfile = Types.LenderProfile with
          lender = lender3
          category = RegionalBank
          rating = A
          totalCapacity = 3000000.0
          availableCapacity = 1000000.0
          activeLoans = 10
          defaultRate = 0.02
          averageInterestRate = 0.08
          geographicFocus = ["Regional"]
        commitment = 200000.0
        role = Participant
        votingPower = 0.20
  
  -- Test RemoveSyndicateParticipant
  syndicatedLoanCid <- submitMulti [leadArranger, lender3] [] do
    exerciseCmd syndicatedLoanCid RemoveSyndicateParticipant with
      participantToRemove = lender3
  
  return ()
