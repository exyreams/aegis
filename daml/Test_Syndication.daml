-- | Comprehensive tests for Syndicated Lending Infrastructure
-- Tests syndicate formation, voting, coordinated payments, and management

module Test_Syndication where

import Daml.Script
import DA.Time
import Test_Setup
import Types
import Syndication

-- SYNDICATE FORMATION TESTS
-- | Test creating a syndicate formation
testSyndicateFormationCreation : Script ()
testSyndicateFormationCreation = do
  parties@Test_Parties{..} <- test_setup
  leadArranger <- allocateParty "LeadArranger"
  
  debug "=== Testing Syndicate Formation Creation ==="
  
  now <- getTime
  
  formationCid <- submit leadArranger do
    createCmd SyndicateFormation with
      formationId = "SYN-FORM-001"
      borrower = alice
      leadArranger
      rfqId = "RFQ-001"
      targetAmount = 500000.0
      commitments = []
      totalCommitted = 0.0
      arrangementFee = 10000.0
      formationDeadline = addRelTime now (days 14)
      status = FormationOpen
  
  debug "Syndicate formation created for $500,000 loan"
  
  Some formation <- queryContractId leadArranger formationCid
  assertMsg "Formation is open" (formation.status == FormationOpen)
  assertMsg "No commitments yet" (length formation.commitments == 0)
  
  debug "=== Syndicate Formation Creation Test Completed ==="

-- | Test lenders committing to syndicate
testCommitToSyndicate : Script ()
testCommitToSyndicate = do
  parties@Test_Parties{..} <- test_setup
  leadArranger <- allocateParty "LeadArranger"
  lender1 <- allocateParty "Lender1"
  lender2 <- allocateParty "Lender2"
  
  debug "=== Testing Syndicate Commitments ==="
  
  now <- getTime
  
  formationCid <- submit leadArranger do
    createCmd SyndicateFormation with
      formationId = "SYN-FORM-002"
      borrower = alice
      leadArranger
      rfqId = "RFQ-002"
      targetAmount = 1000000.0
      commitments = []
      totalCommitted = 0.0
      arrangementFee = 20000.0
      formationDeadline = addRelTime now (days 21)
      status = FormationOpen
  
  debug "Syndicate formation created"
  
  -- Lender 1 commits
  let lender1Profile = LenderProfile with
        lender = lender1
        category = Tier1Bank
        rating = AAA
        totalCapacity = 10000000.0
        availableCapacity = 5000000.0
        activeLoans = 50
        defaultRate = 0.01
        averageInterestRate = 0.06
        geographicFocus = ["US", "EU"]
  
  formationCid <- submit lender1 do
    exerciseCmd formationCid CommitToSyndicate with
      lender = lender1
      profile = lender1Profile
      commitmentAmount = 600000.0
      role = LeadArranger
  
  debug "Lender1 committed $600,000"
  
  -- Lender 2 commits
  let lender2Profile = LenderProfile with
        lender = lender2
        category = RegionalBank
        rating = AA
        totalCapacity = 3000000.0
        availableCapacity = 1500000.0
        activeLoans = 25
        defaultRate = 0.02
        averageInterestRate = 0.075
        geographicFocus = ["US"]
  
  formationCid <- submit lender2 do
    exerciseCmd formationCid CommitToSyndicate with
      lender = lender2
      profile = lender2Profile
      commitmentAmount = 400000.0
      role = Participant
  
  debug "Lender2 committed $400,000"
  
  Some formation <- queryContractId leadArranger formationCid
  assertMsg "Formation is complete" (formation.status == FormationComplete)
  assertMsg "Total committed meets target" (formation.totalCommitted >= formation.targetAmount)
  assertMsg "Two commitments" (length formation.commitments == 2)
  
  debug "=== Syndicate Commitments Test Completed ==="

-- | Test finalizing syndicate and creating loan
testFinalizeSyndicate : Script ()
testFinalizeSyndicate = do
  parties@Test_Parties{..} <- test_setup
  leadArranger <- allocateParty "LeadArranger"
  lender1 <- allocateParty "Lender1"
  
  debug "=== Testing Syndicate Finalization ==="
  
  now <- getTime
  
  let lender1Profile = LenderProfile with
        lender = lender1
        category = Tier1Bank
        rating = AAA
        totalCapacity = 10000000.0
        availableCapacity = 5000000.0
        activeLoans = 50
        defaultRate = 0.01
        averageInterestRate = 0.06
        geographicFocus = ["US"]
  
  let commitment = SyndicateCommitment with
        lender = lender1
        lenderProfile = lender1Profile
        commitmentAmount = 300000.0
        role = Participant
        committedAt = now
  
  formationCid <- submit leadArranger do
    createCmd SyndicateFormation with
      formationId = "SYN-FORM-003"
      borrower = alice
      leadArranger
      rfqId = "RFQ-003"
      targetAmount = 300000.0
      commitments = [commitment]
      totalCommitted = 300000.0
      arrangementFee = 6000.0
      formationDeadline = addRelTime now (days 14)
      status = FormationComplete
  
  debug "Formation complete with commitments"
  
  -- Finalize syndicate
  let rateStructure = InterestRateStructure with
        rateType = Fixed
        baseRate = None
        margin = 0.0
        fixedRate = Some 0.08
        floorRate = None
        capRate = None
        resetFrequency = None
  
  let schedule = RepaymentSchedule with
        frequency = Quarterly
        numberOfPayments = 4
        gracePeriodDays = 5
        lateFeeRate = 0.001
        earlyRepaymentTerms = EarlyRepaymentTerms with
          allowed = True
          penaltyRate = 0.02
          noticePeriodDays = 7
          minimumHoldPeriod = Some (days 30)
        amortizationType = FullyAmortizing
  
  let collateral = 
        [ CollateralAsset with
            assetId = "ETH-001"
            assetType = Cryptocurrency "ETH"
            quantity = 200.0
            currentValue = 300000.0
            initialValue = 300000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  loanCid <- submitMulti [leadArranger, alice] [] do
    exerciseCmd formationCid FinalizeSyndicate with
      interestRateStructure = rateStructure
      repaymentSchedule = schedule
      collateralAssets = collateral
      covenants = []
      loanDuration = days 360
  
  debug "Syndicated loan created"
  
  Some loan <- queryContractId alice loanCid
  assertMsg "Loan has correct commitment" (loan.totalCommitment == 300000.0)
  assertMsg "Loan is active" (loan.status == LoanActive)
  
  debug "=== Syndicate Finalization Test Completed ==="


-- SYNDICATED LOAN TESTS
-- | Test making syndicated payment
testSyndicatedPayment : Script ()
testSyndicatedPayment = do
  parties@Test_Parties{..} <- test_setup
  leadLender <- allocateParty "LeadLender"
  lender1 <- allocateParty "Lender1"
  lender2 <- allocateParty "Lender2"
  
  debug "=== Testing Syndicated Payment ==="
  
  now <- getTime
  
  let participants = 
        [ SyndicateParticipant with
            lender = lender1
            lenderProfile = LenderProfile with
              lender = lender1
              category = Tier1Bank
              rating = AAA
              totalCapacity = 10000000.0
              availableCapacity = 5000000.0
              activeLoans = 50
              defaultRate = 0.01
              averageInterestRate = 0.06
              geographicFocus = ["US"]
            commitment = 600000.0
            role = CoArranger
            votingPower = 0.6
        , SyndicateParticipant with
            lender = lender2
            lenderProfile = LenderProfile with
              lender = lender2
              category = RegionalBank
              rating = AA
              totalCapacity = 3000000.0
              availableCapacity = 1500000.0
              activeLoans = 25
              defaultRate = 0.02
              averageInterestRate = 0.075
              geographicFocus = ["US"]
            commitment = 400000.0
            role = Participant
            votingPower = 0.4
        ]
  
  let rateStructure = InterestRateStructure with
        rateType = Fixed
        baseRate = None
        margin = 0.0
        fixedRate = Some 0.07
        floorRate = None
        capRate = None
        resetFrequency = None
  
  let schedule = RepaymentSchedule with
        frequency = Monthly
        numberOfPayments = 12
        gracePeriodDays = 5
        lateFeeRate = 0.001
        earlyRepaymentTerms = EarlyRepaymentTerms with
          allowed = True
          penaltyRate = 0.02
          noticePeriodDays = 7
          minimumHoldPeriod = Some (days 30)
        amortizationType = FullyAmortizing
  
  let collateral = 
        [ CollateralAsset with
            assetId = "BTC-001"
            assetType = Cryptocurrency "BTC"
            quantity = 25.0
            currentValue = 1000000.0
            initialValue = 1000000.0
            volatilityScore = 0.40
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Coinbase"
            haircut = 0.25
        ]
  
  loanCid <- submitMulti [alice, leadLender, lender1, lender2] [] do
    createCmd SyndicatedLoan with
      loanId = "SYN-LOAN-001"
      borrower = alice
      leadLender
      participants
      totalCommitment = 1000000.0
      outstandingPrincipal = 1000000.0
      interestRateStructure = rateStructure
      repaymentSchedule = schedule
      arrangementFee = 20000.0
      arrangementFeeDistribution = []
      collateralAssets = collateral
      covenants = []
      startDate = now
      maturityDate = addRelTime now (days 360)
      status = LoanActive
      paymentHistory = []
      lastPaymentDate = None
  
  debug "Syndicated loan created"
  
  -- Make payment
  loanCid <- submit alice do
    exerciseCmd loanCid MakeSyndicatedPayment with
      paymentAmount = 90000.0
      principalPortion = 83333.33
      interestPortion = 6666.67
  
  debug "Syndicated payment made - distributed to all lenders"
  
  Some loan <- queryContractId alice loanCid
  assertMsg "Outstanding reduced" (loan.outstandingPrincipal < 1000000.0)
  assertMsg "Payment recorded" (length loan.paymentHistory == 1)
  
  debug "=== Syndicated Payment Test Completed ==="


-- VOTING TESTS
-- | Test syndicate voting mechanism
testSyndicateVoting : Script ()
testSyndicateVoting = do
  parties@Test_Parties{..} <- test_setup
  leadLender <- allocateParty "LeadLender"
  lender1 <- allocateParty "Lender1"
  lender2 <- allocateParty "Lender2"
  
  debug "=== Testing Syndicate Voting ==="
  
  now <- getTime
  
  let participants = 
        [ SyndicateParticipant with
            lender = lender1
            lenderProfile = LenderProfile with
              lender = lender1
              category = Tier1Bank
              rating = AAA
              totalCapacity = 10000000.0
              availableCapacity = 5000000.0
              activeLoans = 50
              defaultRate = 0.01
              averageInterestRate = 0.06
              geographicFocus = ["US"]
            commitment = 500000.0
            role = CoArranger
            votingPower = 0.5
        , SyndicateParticipant with
            lender = lender2
            lenderProfile = LenderProfile with
              lender = lender2
              category = RegionalBank
              rating = AA
              totalCapacity = 3000000.0
              availableCapacity = 1500000.0
              activeLoans = 25
              defaultRate = 0.02
              averageInterestRate = 0.075
              geographicFocus = ["US"]
            commitment = 500000.0
            role = Participant
            votingPower = 0.5
        ]
  
  let rateStructure = InterestRateStructure with
        rateType = Fixed
        baseRate = None
        margin = 0.0
        fixedRate = Some 0.08
        floorRate = None
        capRate = None
        resetFrequency = None
  
  let schedule = RepaymentSchedule with
        frequency = Quarterly
        numberOfPayments = 4
        gracePeriodDays = 5
        lateFeeRate = 0.001
        earlyRepaymentTerms = EarlyRepaymentTerms with
          allowed = True
          penaltyRate = 0.02
          noticePeriodDays = 7
          minimumHoldPeriod = Some (days 30)
        amortizationType = FullyAmortizing
  
  let collateral = 
        [ CollateralAsset with
            assetId = "ETH-002"
            assetType = Cryptocurrency "ETH"
            quantity = 500.0
            currentValue = 750000.0
            initialValue = 750000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  loanCid <- submitMulti [alice, leadLender, lender1, lender2] [] do
    createCmd SyndicatedLoan with
      loanId = "SYN-LOAN-002"
      borrower = alice
      leadLender
      participants
      totalCommitment = 1000000.0
      outstandingPrincipal = 1000000.0
      interestRateStructure = rateStructure
      repaymentSchedule = schedule
      arrangementFee = 20000.0
      arrangementFeeDistribution = []
      collateralAssets = collateral
      covenants = []
      startDate = now
      maturityDate = addRelTime now (days 360)
      status = LoanActive
      paymentHistory = []
      lastPaymentDate = None
  
  debug "Syndicated loan created"
  
  -- Propose a decision
  voteCid <- submit leadLender do
    exerciseCmd loanCid ProposeSyndicateDecision with
      proposer = leadLender
      decisionType = WaiverRequest
      description = "Waive covenant breach due to market conditions"
      votingDeadline = addRelTime now (days 7)
      requiredMajority = 0.66
  
  debug "Decision proposed - waiver request"
  
  -- Lender1 votes for
  voteCid <- submit lender1 do
    exerciseCmd voteCid VoteFor with
      voter = lender1
  
  debug "Lender1 voted in favor"
  
  -- Lender2 votes for
  voteCid <- submit lender2 do
    exerciseCmd voteCid VoteFor with
      voter = lender2
  
  debug "Lender2 voted in favor"
  
  Some vote <- queryContractId leadLender voteCid
  assertMsg "Vote passed" (vote.status == VotePassed)
  
  debug "=== Syndicate Voting Test Completed ==="

-- | Test arrangement fee distribution
