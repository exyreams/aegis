-- | Test canceling syndicate formation
testCancelFormation : Script ()
testCancelFormation = do
  parties@Test_Parties{..} <- test_setup
  leadArranger <- allocateParty "LeadArranger"
  
  debug "=== Testing Cancel Formation ==="
  
  now <- getTime
  
  formationCid <- submit leadArranger do
    createCmd SyndicateFormation with
      formationId = "SYN-FORM-CANCEL"
      borrower = alice
      leadArranger
      rfqId = "RFQ-CANCEL"
      targetAmount = 500000.0
      commitments = []
      totalCommitted = 0.0
      arrangementFee = 10000.0
      formationDeadline = addRelTime now (days 14)
      status = FormationOpen
  
  debug "Formation created"
  
  -- Cancel formation
  submit leadArranger do
    exerciseCmd formationCid CancelFormation with
      reason = "Borrower withdrew request"
  
  debug "Formation cancelled"
  
  debug "=== Cancel Formation Test Completed ==="

-- | Test adding and removing syndicate participants
testManageSyndicateParticipants : Script ()
testManageSyndicateParticipants = do
  parties@Test_Parties{..} <- test_setup
  leadLender <- allocateParty "LeadLender"
  lender1 <- allocateParty "Lender1"
  lender2 <- allocateParty "Lender2"
  
  debug "=== Testing Manage Syndicate Participants ==="
  
  now <- getTime
  
  let participant1 = SyndicateParticipant with
        lender = lender1
        lenderProfile = LenderProfile with
          lender = lender1
          category = Tier1Bank
          rating = AAA
          totalCapacity = 10000000.0
          availableCapacity = 5000000.0
          activeLoans = 50
          defaultRate = 0.01
          averageInterestRate = 0.06
          geographicFocus = ["US"]
        commitment = 500000.0
        role = Participant
        votingPower = 1.0
  
  let rateStructure = InterestRateStructure with
        rateType = Fixed
        baseRate = None
        margin = 0.0
        fixedRate = Some 0.07
        floorRate = None
        capRate = None
        resetFrequency = None
  
  let schedule = RepaymentSchedule with
        frequency = Quarterly
        numberOfPayments = 4
        gracePeriodDays = 5
        lateFeeRate = 0.001
        earlyRepaymentTerms = EarlyRepaymentTerms with
          allowed = True
          penaltyRate = 0.02
          noticePeriodDays = 7
          minimumHoldPeriod = Some (days 30)
        amortizationType = FullyAmortizing
  
  let collateral = 
        [ CollateralAsset with
            assetId = "ETH-003"
            assetType = Cryptocurrency "ETH"
            quantity = 300.0
            currentValue = 450000.0
            initialValue = 450000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  loanCid <- submitMulti [alice, leadLender, lender1] [] do
    createCmd SyndicatedLoan with
      loanId = "SYN-LOAN-MANAGE"
      borrower = alice
      leadLender
      participants = [participant1]
      totalCommitment = 500000.0
      outstandingPrincipal = 500000.0
      interestRateStructure = rateStructure
      repaymentSchedule = schedule
      arrangementFee = 10000.0
      arrangementFeeDistribution = []
      collateralAssets = collateral
      covenants = []
      startDate = now
      maturityDate = addRelTime now (days 360)
      status = LoanActive
      paymentHistory = []
      lastPaymentDate = None
  
  debug "Syndicated loan created with one participant"
  
  -- Add new participant
  let participant2 = SyndicateParticipant with
        lender = lender2
        lenderProfile = LenderProfile with
          lender = lender2
          category = RegionalBank
          rating = AA
          totalCapacity = 3000000.0
          availableCapacity = 1500000.0
          activeLoans = 25
          defaultRate = 0.02
          averageInterestRate = 0.075
          geographicFocus = ["US"]
        commitment = 300000.0
        role = Participant
        votingPower = 0.375
  
  loanCid <- submit leadLender do
    exerciseCmd loanCid AddSyndicateParticipant with
      newParticipant = participant2
  
  debug "New participant added"
  
  Some loan <- queryContractId alice loanCid
  assertMsg "Participant added" (length loan.participants == 2)
  
  -- Remove participant
  loanCid <- submitMulti [leadLender, lender2] [] do
    exerciseCmd loanCid RemoveSyndicateParticipant with
      participantToRemove = lender2
  
  debug "Participant removed"
  
  Some finalLoan <- queryContractId alice loanCid
  assertMsg "Participant removed" (length finalLoan.participants == 1)
  
  debug "=== Manage Syndicate Participants Test Completed ==="

-- | Test voting against a decision
testVoteAgainst : Script ()
testVoteAgainst = do
  parties@Test_Parties{..} <- test_setup
  leadLender <- allocateParty "LeadLender"
  lender1 <- allocateParty "Lender1"
  lender2 <- allocateParty "Lender2"
  
  debug "=== Testing Vote Against ==="
  
  now <- getTime
  
  let participants = 
        [ SyndicateParticipant with
            lender = lender1
            lenderProfile = LenderProfile with
              lender = lender1
              category = Tier1Bank
              rating = AAA
              totalCapacity = 10000000.0
              availableCapacity = 5000000.0
              activeLoans = 50
              defaultRate = 0.01
              averageInterestRate = 0.06
              geographicFocus = ["US"]
            commitment = 400000.0
            role = CoArranger
            votingPower = 0.4
        , SyndicateParticipant with
            lender = lender2
            lenderProfile = LenderProfile with
              lender = lender2
              category = RegionalBank
              rating = AA
              totalCapacity = 3000000.0
              availableCapacity = 1500000.0
              activeLoans = 25
              defaultRate = 0.02
              averageInterestRate = 0.075
              geographicFocus = ["US"]
            commitment = 600000.0
            role = Participant
            votingPower = 0.6
        ]
  
  let rateStructure = InterestRateStructure with
        rateType = Fixed
        baseRate = None
        margin = 0.0
        fixedRate = Some 0.08
        floorRate = None
        capRate = None
        resetFrequency = None
  
  let schedule = RepaymentSchedule with
        frequency = Quarterly
        numberOfPayments = 4
        gracePeriodDays = 5
        lateFeeRate = 0.001
        earlyRepaymentTerms = EarlyRepaymentTerms with
          allowed = True
          penaltyRate = 0.02
          noticePeriodDays = 7
          minimumHoldPeriod = Some (days 30)
        amortizationType = FullyAmortizing
  
  let collateral = 
        [ CollateralAsset with
            assetId = "BTC-003"
            assetType = Cryptocurrency "BTC"
            quantity = 25.0
            currentValue = 1000000.0
            initialValue = 1000000.0
            volatilityScore = 0.40
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Coinbase"
            haircut = 0.25
        ]
  
  loanCid <- submitMulti [alice, leadLender, lender1, lender2] [] do
    createCmd SyndicatedLoan with
      loanId = "SYN-LOAN-VOTE"
      borrower = alice
      leadLender
      participants
      totalCommitment = 1000000.0
      outstandingPrincipal = 1000000.0
      interestRateStructure = rateStructure
      repaymentSchedule = schedule
      arrangementFee = 20000.0
      arrangementFeeDistribution = []
      collateralAssets = collateral
      covenants = []
      startDate = now
      maturityDate = addRelTime now (days 360)
      status = LoanActive
      paymentHistory = []
      lastPaymentDate = None
  
  debug "Syndicated loan created"
  
  -- Propose a decision
  voteCid <- submit leadLender do
    exerciseCmd loanCid ProposeSyndicateDecision with
      proposer = leadLender
      decisionType = AmendmentProposal
      description = "Increase interest rate by 1%"
      votingDeadline = addRelTime now (days 7)
      requiredMajority = 0.66
  
  debug "Decision proposed"
  
  -- Lender1 votes against
  voteCid <- submit lender1 do
    exerciseCmd voteCid VoteAgainst with
      voter = lender1
  
  debug "Lender1 voted against"
  
  -- Lender2 votes for
  voteCid <- submit lender2 do
    exerciseCmd voteCid VoteFor with
      voter = lender2
  
  debug "Lender2 voted for"
  
  Some vote <- queryContractId leadLender voteCid
  assertMsg "Vote still pending" (vote.status == VotePending)
  assertMsg "One vote against" (length vote.votesAgainst == 1)
  
  debug "=== Vote Against Test Completed ==="

