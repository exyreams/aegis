      votesAgainst = []
      requiredMajority = 0.66
      proposedAt = now
      votingDeadline = addRelTime now (days 7)
      status = VotePending
  
  submit leadArranger do
    archiveCmd voteCid
  
  -- Archive SyndicatedLoan
  loanCid <- submitMulti [alice, leadArranger, lender1] [] do
    createCmd SyndicatedLoan with
      loanId = "SYN-ARCH"
      borrower = alice
      leadLender = leadArranger
      participants = [SyndicateParticipant with
        lender = lender1
        lenderProfile
        commitment = 500000.0
        role = Participant
        votingPower = 1.0]
      totalCommitment = 500000.0
      outstandingPrincipal = 0.0
      interestRateStructure = InterestRateStructure with
        rateType = Fixed
        baseRate = None
        margin = 0.0
        fixedRate = Some 0.08
        floorRate = None
        capRate = None
        resetFrequency = None
      repaymentSchedule = RepaymentSchedule with
        frequency = Quarterly
        numberOfPayments = 4
        gracePeriodDays = 5
        lateFeeRate = 0.001
        earlyRepaymentTerms = EarlyRepaymentTerms with
          allowed = True
          penaltyRate = 0.02
          noticePeriodDays = 7
          minimumHoldPeriod = Some (days 30)
        amortizationType = FullyAmortizing
      arrangementFee = 10000.0
      arrangementFeeDistribution = []
      collateralAssets = []
      covenants = []
      startDate = now
      maturityDate = addRelTime now (days 360)
      status = LoanRepaid
      paymentHistory = []
      lastPaymentDate = None
  
  submitMulti [alice, leadArranger, lender1] [] do
    archiveCmd loanCid
  
  return ()

