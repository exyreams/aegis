            quantity = 300.0
            currentValue = 450000.0
            initialValue = 450000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  loanCid <- submitMulti [alice, leadLender, lender1] [] do
    createCmd SyndicatedLoan with
      loanId = "SYN-LOAN-FINALIZE"
      borrower = alice
      leadLender
      participants
      totalCommitment = 500000.0
      outstandingPrincipal = 500000.0
      interestRateStructure = rateStructure
      repaymentSchedule = schedule
      arrangementFee = 10000.0
      arrangementFeeDistribution = []
      collateralAssets = collateral
      covenants = []
      startDate = now
      maturityDate = addRelTime now (days 360)
      status = LoanActive
      paymentHistory = []
      lastPaymentDate = None
  
  debug "Syndicated loan created"
  
  -- Propose a decision with short deadline
  let votingDeadline = addRelTime now (seconds 1)
  voteCid <- submit leadLender do
    exerciseCmd loanCid ProposeSyndicateDecision with
      proposer = leadLender
      decisionType = WaiverRequest
      description = "Waive late fee"
      votingDeadline
      requiredMajority = 0.5
  
  debug "Decision proposed with short deadline"
  
  -- Wait for deadline to pass
  passTime (seconds 2)
  
  -- Finalize vote
  result <- submit leadLender do
    exerciseCmd voteCid FinalizeVote
  
  debug "Vote finalized after deadline"
  
  assertMsg "Vote result returned" (result.voteId /= "")
  
  debug "=== Finalize Vote Test Completed ==="

-- | Run all syndication tests
runAllSyndicationTests : Script ()
runAllSyndicationTests = do
  testSyndicateFormationCreation
  -- testCommitToSyndicate  -- TODO: Fix authorization issues
  -- testFinalizeSyndicate  -- TODO: Fix authorization issues
  testSyndicatedPayment
  testSyndicateVoting
  testArrangementFeeDistribution
  testSyndicateReporting
  testCancelFormation
  -- testManageSyndicateParticipants  -- TODO: Fix authorization issues
  testVoteAgainst
  testFinalizeVote
  testArchiveSyndicateFormation
  -- testCompleteSyndicationWorkflow  -- TODO: Fix authorization issues
  debug "=== All Syndication Tests Completed Successfully ==="


-- SYNDICATE REPORTING TESTS
-- | Test syndicate reporting
testSyndicateReporting : Script ()
testSyndicateReporting = do
  parties@Test_Parties{..} <- test_setup
  leadLender <- allocateParty "ReportLeadLender"
  lender1 <- allocateParty "ReportLender1"
  
  debug "=== Testing Syndicate Reporting ==="
  
  now <- getTime
  
  reportCid <- submit leadLender do
    createCmd SyndicateReport with
      reportId = "REPORT-001"
      loanId = "SYN-LOAN-REPORT-001"
      leadLender
      participants = [lender1]
      reportingPeriodStart = now
      reportingPeriodEnd = addRelTime now (days 30)
      totalPaymentsReceived = 25000.0
      outstandingPrincipal = 400000.0
      loanPerformance = "Excellent - all payments on time"
      covenantCompliance = [("Debt-to-equity ratio < 2.0", True), ("Minimum liquidity $100k", True)]
      generatedAt = now
  
  debug "Syndicate report created"
  
  -- Acknowledge report
  reportCid <- submit lender1 do
    exerciseCmd reportCid AcknowledgeReport with
      participant = lender1
  
  debug "Report acknowledged by participant"
  
  debug "=== Syndicate Reporting Test Completed ==="

-- | Test Archive choices
testSyndicationArchives : Script ()
testSyndicationArchives = do
  parties@Test_Parties{..} <- test_setup
  leadArranger <- allocateParty "ArchLeader"
  lender1 <- allocateParty "ArchLender1"
  
  now <- getTime
  
  let lenderProfile = LenderProfile with
        lender = lender1
        category = Tier1Bank
        rating = AAA
        totalCapacity = 10000000.0
        availableCapacity = 5000000.0
        activeLoans = 50
        defaultRate = 0.01
        averageInterestRate = 0.06
        geographicFocus = ["US"]
  
