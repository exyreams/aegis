        treasuryBalances = [(Stablecoin "USDC", 2000000.0)]
        reserveRatio = 0.15
        lastAuditDate = now
  
  platformCid <- submitMulti [platform, emergencyOp, complianceOff] [] do
    createCmd Aegis.AegisPlatform with
      platform
      treasury = initialTreasury
      authorizedAssets = [Stablecoin "USDC"]
      platformFeeRate = 0.005  -- 0.5% fee
      emergencyOperator = emergencyOp
      complianceOfficer = complianceOff
      totalLoansOriginated = 0.0
      totalFeesCollected = 0.0
      activeLenders = [lender]
      platformStatus = PlatformActive
  
  debug "Aegis platform initialized"
  
  -- Create loan using RFQ helper function
  let collateral = [CollateralAsset with
        assetId = "ETH-PLATFORM-001"
        assetType = Cryptocurrency "ETH"
        quantity = 100.0
        currentValue = 150000.0
        initialValue = 150000.0
        volatilityScore = 0.35
        liquidityRating = HighlyLiquid
        lastValuationTime = now
        valuationSource = "Chainlink"
        haircut = 0.20]
  
  let interestRate = InterestRateStructure with
        rateType = Fixed
        baseRate = None
        margin = 0.0
        fixedRate = Some 0.08
        floorRate = None
        capRate = None
        resetFrequency = None
  
  let repaymentSched = RepaymentSchedule with
        frequency = Monthly
        numberOfPayments = 12
        gracePeriodDays = 5
        lateFeeRate = 0.001
        earlyRepaymentTerms = EarlyRepaymentTerms with
          allowed = True
          penaltyRate = 0.02
          noticePeriodDays = 5
          minimumHoldPeriod = Some (days 30)
        amortizationType = FullyAmortizing
  
  let privacy = PrivacySettings with
        visibilityMode = CompletelyPrivate
        allowSecondaryMarket = True
        dataRetentionDays = 365
        anonymizeBorrower = False
        restrictedDataFields = []
  
  let lenderProfile = LenderProfile with
        lender
        category = Tier1Bank
        rating = AAA
        totalCapacity = 10000000.0
        availableCapacity = 5000000.0
        activeLoans = 20
        defaultRate = 0.01
        averageInterestRate = 0.07
        geographicFocus = ["Global"]
  
  let maturityDate = addRelTime now (days 365)
  
  -- Note: createLoanWithPlatformFee is an Update function, not directly callable in Script
  -- We'll create the loan manually and collect fee separately
  loanCid <- submitMulti [alice, lender] [] do
    createCmd Loan with
      loanId = "LOAN-PLATFORM-001"
      borrower = alice
      lenders = [lender]
      lenderProfiles = [lenderProfile]
      principal = 100000.0
      outstandingPrincipal = 100000.0
      collateralAssets = collateral
      interestRateStructure = interestRate
      repaymentSchedule = repaymentSched
      covenants = []
      additionalTerms = "Loan with platform fee"
      privacySettings = privacy
      startDate = now
      maturityDate
      status = LoanActive
      paymentHistory = []
      lastPaymentDate = None
      totalInterestPaid = 0.0
      totalPrincipalPaid = 0.0
  
  -- Collect platform fee using Aegis directly
  newPlatformCid <- submit platform do
    exerciseCmd platformCid Aegis.CollectPlatformFee with
      loanId = "LOAN-PLATFORM-001"
      loanAmount = 100000.0
      lender
      assetType = Stablecoin "USDC"
  
  debug "Loan created with platform fee collection"
  
  -- Verify platform fee was collected
  Some plat <- queryContractId platform newPlatformCid
  assertMsg "Platform fee collected (500 USDC)" (plat.totalFeesCollected == 500.0)
  debug "✓ Platform fee of 500 USDC collected (0.5% of 100K)"
  
  -- Verify loan was created
  Some loan <- queryContractId alice loanCid
  assertMsg "Loan created with correct principal" (loan.principal == 100000.0)
  assertMsg "Loan is active" (loan.status == LoanActive)
  
  debug "✓ Loan created successfully with platform integration"
  debug "=== createLoanWithPlatformFee Test Completed ==="
-}

-- | Test RFQ helper: handleLoanDefault with platform reimbursement
testHandleLoanDefaultWithPlatform : Script ()
testHandleLoanDefaultWithPlatform = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "DefaultLender"
  platform <- allocateParty "AegisPlatform4"
  emergencyOp <- allocateParty "EmergencyOp4"
  complianceOff <- allocateParty "ComplianceOff4"
  
  debug "=== Testing handleLoanDefault Helper ==="
  
