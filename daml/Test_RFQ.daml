        baseRate = None
        margin = 0.0
        fixedRate = Some 0.12
        floorRate = None
        capRate = None
        resetFrequency = None
      repaymentSchedule = RepaymentSchedule with
        frequency = Monthly
        numberOfPayments = 6
        gracePeriodDays = 3
        lateFeeRate = 0.005
