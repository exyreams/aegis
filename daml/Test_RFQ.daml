-- | Test complete RFQ workflow: SubmitBid -> AcceptBid -> AcceptLoan
testCompleteRFQWorkflow : Script ()
testCompleteRFQWorkflow = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "WorkflowLender"
  
  now <- getTime
  
  let collateral = 
        [ CollateralAsset with
            assetId = "ETH-WORKFLOW"
            assetType = Cryptocurrency "ETH"
            quantity = 200.0
            currentValue = 300000.0
            initialValue = 300000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  let lenderProfile = LenderProfile with
        lender
        category = Tier1Bank
        rating = AAA
        totalCapacity = 10000000.0
        availableCapacity = 5000000.0
        activeLoans = 20
        defaultRate = 0.01
        averageInterestRate = 0.07
        geographicFocus = ["Global"]
  
  let collateralReqs = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH"]
        maximumConcentration = 1.0
  
  -- Create RFQ
  rfqCid <- submit alice do
    createCmd RFQ with
      borrower = alice
      rfqId = "RFQ-WORKFLOW"
      loanAmount = 100000.0
      collateralAssets = collateral
      loanDuration = days 90
      loanPurpose = "Working Capital"
      lenderCriteria = LenderCriteria with
        categories = [Tier1Bank]
        minimumRating = A
        geographicRestrictions = []
        maximumBids = 5
        requiredCapacity = 100000.0
        preferredLenders = [lender]
      privacySettings = PrivacySettings with
        visibilityMode = CompletelyPrivate
        allowSecondaryMarket = True
        dataRetentionDays = 365
        anonymizeBorrower = False
        restrictedDataFields = []
      collateralRequirements = collateralReqs
      status = RFQActive
      createdAt = now
      expiresAt = addRelTime now (days 14)
      currentBidCount = 0
      acceptedBidId = None
  
  -- Test SubmitBid
  bidResult <- submit lender do
    exerciseCmd rfqCid SubmitBid with
      lender
      lenderProfile
      interestRateStructure = InterestRateStructure with
        rateType = Fixed
        baseRate = None
        margin = 0.0
        fixedRate = Some 0.08
        floorRate = None
        capRate = None
        resetFrequency = None
      repaymentSchedule = RepaymentSchedule with
        frequency = Monthly
        numberOfPayments = 3
        gracePeriodDays = 5
        lateFeeRate = 0.001
        earlyRepaymentTerms = EarlyRepaymentTerms with
          allowed = True
          penaltyRate = 0.02
          noticePeriodDays = 5
          minimumHoldPeriod = Some (days 15)
        amortizationType = FullyAmortizing
      proposedCovenants = []
      additionalTerms = "Standard terms"
  
  bidCid <- case bidResult of
    Left err -> abort ("Bid submission failed: " <> err)
    Right cid -> return cid
  
  -- Test AcceptBid
  proposalResult <- submit alice do
    exerciseCmd rfqCid AcceptBid with
      bidCid
  
  proposalCid <- case proposalResult of
    Left err -> abort ("Accept bid failed: " <> err)
    Right cid -> return cid
  
  -- Test AcceptLoan
  loanCid <- submitMulti [alice, lender] [] do
    exerciseCmd proposalCid AcceptLoan
  
  return ()

