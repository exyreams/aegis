      platformStatus = PlatformActive
  
  debug "Aegis platform initialized with 5M USDC treasury"
  
  -- Create a loan that will default
  let lenderProfile = LenderProfile with
        lender
        category = Tier1Bank
        rating = AAA
        totalCapacity = 10000000.0
        availableCapacity = 5000000.0
        activeLoans = 20
        defaultRate = 0.01
        averageInterestRate = 0.07
        geographicFocus = ["Global"]
  
  let collateral = [CollateralAsset with
        assetId = "ETH-DEFAULT-001"
        assetType = Cryptocurrency "ETH"
        quantity = 50.0
        currentValue = 75000.0
        initialValue = 75000.0
        volatilityScore = 0.35
        liquidityRating = HighlyLiquid
        lastValuationTime = now
        valuationSource = "Chainlink"
        haircut = 0.20]
  
  loanCid <- submitMulti [alice, lender] [] do
    createCmd Loan with
      loanId = "LOAN-DEFAULT-PLATFORM"
