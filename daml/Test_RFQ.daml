        dataRetentionDays = 365
        anonymizeBorrower = False
        restrictedDataFields = []
      startDate = now
      maturityDate = addRelTime now (days 365)
      status = LoanActive
      paymentHistory = []
      lastPaymentDate = None
      totalInterestPaid = 0.0
      totalPrincipalPaid = 0.0
  
  debug "Loan created"
  
  -- Restructure loan
  loanCid <- submitMulti [alice, lender] [] do
    exerciseCmd loanCid RestructureLoan with
      newInterestRateStructure = InterestRateStructure with
        rateType = Fixed
        baseRate = None
        margin = 0.0
        fixedRate = Some 0.08
        floorRate = None
        capRate = None
        resetFrequency = None
      newRepaymentSchedule = RepaymentSchedule with
        frequency = Monthly
        numberOfPayments = 18
        gracePeriodDays = 5
        lateFeeRate = 0.001
        earlyRepaymentTerms = EarlyRepaymentTerms with
          allowed = True
          penaltyRate = 0.02
          noticePeriodDays = 5
          minimumHoldPeriod = Some (days 30)
        amortizationType = FullyAmortizing
      newMaturityDate = addRelTime now (days 540)
  
  debug "Loan restructured"
  
  Some loan <- queryContractId alice loanCid
  assertMsg "Loan status is restructured" (loan.status == LoanRestructured)
  
  debug "=== Loan Restructuring Test Completed ==="



