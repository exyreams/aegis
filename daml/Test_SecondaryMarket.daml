-- | Comprehensive tests for Secondary Market and Loan Trading System
-- Tests loan listings, offers, transfers, and valuations

module Test_SecondaryMarket where

import Daml.Script
import DA.Time
import Test_Setup
import Types
import RFQ
import SecondaryMarket
-- import qualified Aegis  -- Commented out - used in testTransferWithPlatformFee (deployment only)

-- LOAN LISTING TESTS
-- | Test creating a loan listing
testLoanListingCreation : Script ()
testLoanListingCreation = do
  parties@Test_Parties{..} <- test_setup
  
  debug "=== Testing Loan Listing Creation ==="
  
  now <- getTime
  
  let performanceMetrics = LoanPerformanceMetrics with
        paymentsOnTime = 5
        paymentsMissed = 0
        totalPaymentsMade = 5
        averageDaysLate = 0.0
        currentStatus = LoanCurrent
  
  listingCid <- submit alice do
    createCmd LoanListing with
      listingId = "LISTING-001"
      seller = alice
      loanId = "LOAN-001"
      loanAmount = 100000.0
      outstandingPrincipal = 80000.0
      interestRate = 0.08
      maturityDate = addRelTime now (days 180)
      collateralValue = 120000.0
      loanPerformance = performanceMetrics
      askingPrice = 82000.0
      privacyLevel = PartialDisclosure
      listedAt = now
      expiresAt = addRelTime now (days 30)
      status = ListingActive
  
  debug "Loan listing created successfully"
  
  Some listing <- queryContractId alice listingCid
  assertMsg "Listing is active" (listing.status == ListingActive)
  assertMsg "Asking price is reasonable" (listing.askingPrice > listing.outstandingPrincipal * 0.9)
  
  debug "=== Loan Listing Creation Test Completed ==="

-- | Test making an offer on a loan
testMakeOffer : Script ()
testMakeOffer = do
  parties@Test_Parties{..} <- test_setup
  buyer <- allocateParty "Buyer"
  
  debug "=== Testing Loan Offer ==="
  
  now <- getTime
  
  let performanceMetrics = LoanPerformanceMetrics with
        paymentsOnTime = 8
        paymentsMissed = 0
        totalPaymentsMade = 8
        averageDaysLate = 0.0
        currentStatus = LoanCurrent
  
  listingCid <- submit alice do
    createCmd LoanListing with
      listingId = "LISTING-002"
      seller = alice
      loanId = "LOAN-002"
      loanAmount = 50000.0
      outstandingPrincipal = 40000.0
      interestRate = 0.10
      maturityDate = addRelTime now (days 90)
      collateralValue = 60000.0
      loanPerformance = performanceMetrics
      askingPrice = 41000.0
      privacyLevel = FullDisclosure
      listedAt = now
      expiresAt = addRelTime now (days 15)
      status = ListingActive
  
  debug "Loan listed for sale"
  
  -- Buyer makes an offer (seller exercises on behalf to make listing visible)
  offerCid <- submit alice do
    exerciseCmd listingCid MakeOffer with
      buyer
      offerPrice = 40500.0
      offerExpiresAt = addRelTime now (days 7)
  
  debug "Buyer made offer of $40,500"
  
  Some offer <- queryContractId buyer offerCid
  assertMsg "Offer is pending" (offer.status == OfferPending)
  assertMsg "Offer price is correct" (offer.offerPrice == 40500.0)
  
  debug "=== Loan Offer Test Completed ==="

-- | Test accepting an offer and creating transfer
testAcceptOffer : Script ()
testAcceptOffer = do
  parties@Test_Parties{..} <- test_setup
  buyer <- allocateParty "Buyer"
  
  debug "=== Testing Offer Acceptance ==="
  
  now <- getTime
  
  let performanceMetrics = LoanPerformanceMetrics with
        paymentsOnTime = 10
        paymentsMissed = 1
        totalPaymentsMade = 11
        averageDaysLate = 2.0
        currentStatus = LoanCurrent
  
  listingCid <- submit alice do
    createCmd LoanListing with
      listingId = "LISTING-003"
      seller = alice
      loanId = "LOAN-003"
      loanAmount = 75000.0
      outstandingPrincipal = 60000.0
      interestRate = 0.09
      maturityDate = addRelTime now (days 120)
      collateralValue = 90000.0
      loanPerformance = performanceMetrics
      askingPrice = 61000.0
      privacyLevel = PartialDisclosure
      listedAt = now
      expiresAt = addRelTime now (days 20)
      status = ListingActive
  
  debug "Loan listed"
  
  -- Buyer makes offer
  offerCid <- submit buyer do
    exerciseCmd listingCid MakeOffer with
      buyer
      offerPrice = 60500.0
      offerExpiresAt = addRelTime now (days 5)
  
  debug "Offer made"
  
  -- Seller accepts offer
  transferCid <- submit alice do
    exerciseCmd listingCid AcceptOffer with
      offerCid
      borrower = bob
  
  debug "Offer accepted, transfer created"
  
  Some transfer <- queryContractId alice transferCid
  assertMsg "Transfer is pending" (transfer.status == TransferPending)
  assertMsg "Transfer price matches offer" (transfer.transferPrice == 60500.0)
  assertMsg "Borrower is notified" (transfer.borrower == bob)
  
  debug "=== Offer Acceptance Test Completed ==="

-- | Test loan valuation
testLoanValuation : Script ()
testLoanValuation = do
  parties@Test_Parties{..} <- test_setup
  valuator <- allocateParty "Valuator"
  
  debug "=== Testing Loan Valuation ==="
  
  now <- getTime
  
  let performanceMetrics = LoanPerformanceMetrics with
        paymentsOnTime = 12
        paymentsMissed = 0
        totalPaymentsMade = 12
        averageDaysLate = 0.0
        currentStatus = LoanCurrent
  
  let fairValue = SecondaryMarket.calculateLoanFairValue 
        50000.0  -- outstanding principal
        0.08     -- interest rate
        0.10     -- discount rate
        (days 180)  -- remaining term
  
  valuationCid <- submit valuator do
    createCmd LoanValuation with
      valuationId = "VAL-001"
      valuator
      loanId = "LOAN-004"
      loanAmount = 60000.0
      outstandingPrincipal = 50000.0
      interestRate = 0.08
      remainingTerm = days 180
      collateralValue = 75000.0
      borrowerCreditScore = 720
      loanPerformance = performanceMetrics
      fairValue
      discountRate = 0.10
      riskPremium = 0.02
      valuationDate = now
  
  debug "Loan valuation created"
  
  Some valuation <- queryContractId valuator valuationCid
  assertMsg "Fair value calculated" (valuation.fairValue > 0.0)
  assertMsg "Discount rate applied" (valuation.discountRate == 0.10)
  
  -- Update valuation
  valuationCid <- submit valuator do
    exerciseCmd valuationCid UpdateValuation with
      newFairValue = fairValue * 1.05
      newDiscountRate = 0.09
      newRiskPremium = 0.015
  
  debug "Valuation updated"
  
  Some updatedValuation <- queryContractId valuator valuationCid
  assertMsg "Valuation was updated" (updatedValuation.discountRate == 0.09)
  
  debug "=== Loan Valuation Test Completed ==="

-- | Test borrower notification
testBorrowerNotification : Script ()
testBorrowerNotification = do
  parties@Test_Parties{..} <- test_setup
  oldLender <- allocateParty "OldLender"
  newLender <- allocateParty "NewLender"
  
  debug "=== Testing Borrower Notification ==="
  
  now <- getTime
  
  notificationCid <- submitMulti [alice, oldLender, newLender] [] do
    createCmd BorrowerNotification with
      notificationId = "NOTIF-001"
      borrower = alice
      oldLender
      newLender
      loanId = "LOAN-005"
      transferDate = now
      acknowledged = False
  
  debug "Notification created"
  
  -- Borrower acknowledges
  notificationCid <- submit alice do
    exerciseCmd notificationCid AcknowledgeNotification
  
  debug "Borrower acknowledged lender change"
  
  Some notification <- queryContractId alice notificationCid
  assertMsg "Notification acknowledged" notification.acknowledged
  
  debug "=== Borrower Notification Test Completed ==="

-- | Test updating asking price
testUpdateAskingPrice : Script ()
testUpdateAskingPrice = do
  parties@Test_Parties{..} <- test_setup
  
  debug "=== Testing Asking Price Update ==="
  
  now <- getTime
  
  let performanceMetrics = LoanPerformanceMetrics with
        paymentsOnTime = 6
        paymentsMissed = 0
        totalPaymentsMade = 6
        averageDaysLate = 0.0
        currentStatus = LoanCurrent
  
  listingCid <- submit alice do
    createCmd LoanListing with
      listingId = "LISTING-004"
      seller = alice
      loanId = "LOAN-006"
      loanAmount = 30000.0
      outstandingPrincipal = 25000.0
      interestRate = 0.07
      maturityDate = addRelTime now (days 60)
      collateralValue = 35000.0
      loanPerformance = performanceMetrics
      askingPrice = 26000.0
      privacyLevel = FullDisclosure
      listedAt = now
      expiresAt = addRelTime now (days 10)
      status = ListingActive
  
  debug "Loan listed at $26,000"
  
  -- Update asking price
  listingCid <- submit alice do
    exerciseCmd listingCid UpdateAskingPrice with
      newPrice = 25500.0
  
  debug "Asking price reduced to $25,500"
  
  Some listing <- queryContractId alice listingCid
  assertMsg "Price was updated" (listing.askingPrice == 25500.0)
  
  debug "=== Asking Price Update Test Completed ==="

-- | Test canceling a listing
testCancelListing : Script ()
testCancelListing = do
  parties@Test_Parties{..} <- test_setup
  
  debug "=== Testing Listing Cancellation ==="
  
  now <- getTime
  
  let performanceMetrics = LoanPerformanceMetrics with
        paymentsOnTime = 4
