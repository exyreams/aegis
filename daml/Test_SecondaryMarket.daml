-- | Test complete secondary market workflow: MakeOffer -> AcceptOffer -> ExecuteTransfer -> AcknowledgeSettlement
testCompleteSecondaryMarketWorkflow : Script ()
testCompleteSecondaryMarketWorkflow = do
  parties@Test_Parties{..} <- test_setup
  seller <- allocateParty "WorkflowSeller"
  buyer <- allocateParty "WorkflowBuyer"
  
  now <- getTime
  
  -- Create listing
  listingCid <- submit seller do
    createCmd LoanListing with
      listingId = "LIST-WORKFLOW"
      seller
      loanId = "LOAN-WORKFLOW"
      loanAmount = 100000.0
      outstandingPrincipal = 80000.0
      interestRate = 0.08
      maturityDate = addRelTime now (days 180)
      collateralValue = 120000.0
      loanPerformance = LoanPerformanceMetrics with
        paymentsOnTime = 5
        paymentsMissed = 0
        totalPaymentsMade = 5
        averageDaysLate = 0.0
        currentStatus = LoanCurrent
      askingPrice = 82000.0
      privacyLevel = FullDisclosure
      listedAt = now
      expiresAt = addRelTime now (days 30)
      status = ListingActive
  
  -- Test MakeOffer
  offerCid <- submit buyer do
    exerciseCmd listingCid MakeOffer with
      buyer
      offerPrice = 80000.0
      offerExpiresAt = addRelTime now (days 7)
  
  -- Create loan for transfer
  let lenderProfile = LenderProfile with
        lender = seller
        category = Tier1Bank
        rating = AAA
        totalCapacity = 10000000.0
        availableCapacity = 5000000.0
        activeLoans = 20
        defaultRate = 0.01
        averageInterestRate = 0.07
        geographicFocus = ["Global"]
  
  loanCid <- submitMulti [alice, seller] [] do
    createCmd Loan with
      loanId = "LOAN-WORKFLOW"
      borrower = alice
      lenders = [seller]
      lenderProfiles = [lenderProfile]
      principal = 100000.0
      outstandingPrincipal = 80000.0
      collateralAssets = []
      interestRateStructure = InterestRateStructure with
        rateType = Fixed
        baseRate = None
        margin = 0.0
        fixedRate = Some 0.08
        floorRate = None
        capRate = None
        resetFrequency = None
      repaymentSchedule = RepaymentSchedule with
        frequency = Monthly
        numberOfPayments = 12
        gracePeriodDays = 5
        lateFeeRate = 0.001
        earlyRepaymentTerms = EarlyRepaymentTerms with
          allowed = True
          penaltyRate = 0.02
          noticePeriodDays = 5
          minimumHoldPeriod = Some (days 30)
        amortizationType = FullyAmortizing
      covenants = []
      additionalTerms = ""
      privacySettings = PrivacySettings with
        visibilityMode = CompletelyPrivate
        allowSecondaryMarket = True
        dataRetentionDays = 365
        anonymizeBorrower = False
        restrictedDataFields = []
      startDate = now
      maturityDate = addRelTime now (days 180)
      status = LoanCurrent
      paymentHistory = []
      lastPaymentDate = None
      totalInterestPaid = 0.0
      totalPrincipalPaid = 20000.0
  
  -- Test AcceptOffer
  transferCid <- submit seller do
    exerciseCmd listingCid AcceptOffer with
      offerCid
      borrower = alice
  
  -- Test ExecuteTransfer
  settlementCid <- submitMulti [seller, buyer] [] do
    exerciseCmd transferCid ExecuteTransfer with
      originalLoanCid = loanCid
      transferFee = 1000.0
  
  -- Test AcknowledgeSettlement
  submitMulti [seller, buyer, alice] [] do
    exerciseCmd settlementCid AcknowledgeSettlement with
      party = alice
  
  return ()

