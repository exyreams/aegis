        totalPaymentsMade = 4
        averageDaysLate = 0.0
        currentStatus = LoanCurrent
  
  listingCid <- submit alice do
    createCmd LoanListing with
      listingId = "LISTING-005"
      seller = alice
      loanId = "LOAN-007"
      loanAmount = 20000.0
      outstandingPrincipal = 18000.0
      interestRate = 0.06
      maturityDate = addRelTime now (days 45)
      collateralValue = 25000.0
      loanPerformance = performanceMetrics
      askingPrice = 18500.0
      privacyLevel = AnonymousListing
      listedAt = now
      expiresAt = addRelTime now (days 7)
      status = ListingActive
  
  debug "Loan listed"
  
  -- Cancel listing
