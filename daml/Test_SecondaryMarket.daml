-- | Test Archive choices
testSecondaryMarketArchives : Script ()
testSecondaryMarketArchives = do
  parties@Test_Parties{..} <- test_setup
  seller <- allocateParty "ArchSeller"
  buyer <- allocateParty "ArchBuyer"
  
  now <- getTime
  
  -- Archive LoanOffer
  listingCid <- submit seller do
    createCmd LoanListing with
      listingId = "LIST-ARCH"
      seller
      loanId = "LOAN-ARCH"
      loanAmount = 100000.0
      outstandingPrincipal = 80000.0
      interestRate = 0.08
      maturityDate = addRelTime now (days 180)
      collateralValue = 120000.0
      loanPerformance = LoanPerformanceMetrics with
        paymentsOnTime = 5
        paymentsMissed = 0
        totalPaymentsMade = 5
        averageDaysLate = 0.0
        currentStatus = LoanCurrent
      askingPrice = 82000.0
      privacyLevel = FullDisclosure
      listedAt = now
      expiresAt = addRelTime now (days 30)
      status = ListingActive
  
  offerCid <- submit buyer do
    createCmd LoanOffer with
      offerId = "OFFER-ARCH"
      listingId = "LIST-ARCH"
      seller
      buyer
      loanId = "LOAN-ARCH"
      offerPrice = 80000.0
      offerExpiresAt = addRelTime now (days 7)
      status = OfferPending
  
  submit buyer do
    archiveCmd offerCid
  
  -- Archive LoanValuation
  valuationCid <- submit seller do
    createCmd LoanValuation with
      valuationId = "VAL-ARCH"
      valuator = seller
      loanId = "LOAN-ARCH"
      loanAmount = 100000.0
      outstandingPrincipal = 80000.0
      interestRate = 0.08
      remainingTerm = days 180
      collateralValue = 120000.0
      borrowerCreditScore = 720
      loanPerformance = LoanPerformanceMetrics with
        paymentsOnTime = 5
        paymentsMissed = 0
        totalPaymentsMade = 5
        averageDaysLate = 0.0
        currentStatus = LoanCurrent
      fairValue = 82000.0
      discountRate = 0.05
      riskPremium = 0.02
      valuationDate = now
  
  submit seller do
    archiveCmd valuationCid
  
  -- Archive BorrowerNotification
  notificationCid <- submitMulti [alice, seller, buyer] [] do
    createCmd BorrowerNotification with
      notificationId = "NOTIF-ARCH"
      borrower = alice
      oldLender = seller
      newLender = buyer
      loanId = "LOAN-ARCH"
      transferDate = now
      acknowledged = False
  
  submitMulti [alice, seller, buyer] [] do
    archiveCmd notificationCid
  
  -- Archive SecondaryLoanTransfer
  transferCid <- submitMulti [seller, buyer] [] do
    createCmd SecondaryLoanTransfer with
      transferId = "TRANS-ARCH"
      seller
      buyer
      borrower = alice
      loanId = "LOAN-ARCH"
      transferPrice = 80000.0
      outstandingPrincipal = 80000.0
      interestRate = 0.08
      maturityDate = addRelTime now (days 180)
      collateralValue = 120000.0
      initiatedAt = now
      status = TransferPending
  
  submitMulti [seller, buyer] [] do
    archiveCmd transferCid
  
  -- Archive TransferSettlement
  settlementCid <- submitMulti [seller, buyer] [] do
    createCmd TransferSettlement with
      settlementId = "SETTLE-ARCH"
      seller
      buyer
      borrower = alice
      loanId = "LOAN-ARCH"
      transferPrice = 80000.0
      transferFee = 1000.0
      netProceeds = 79000.0
      settledAt = now
  
  submitMulti [seller, buyer] [] do
    archiveCmd settlementCid
  
  return ()

