    exerciseCmd listingCid CancelListing with
      reason = "Changed mind about selling"
  
  debug "Listing cancelled"
  
  debug "=== Listing Cancellation Test Completed ==="

-- | Test offer withdrawal
testOfferWithdrawal : Script ()
testOfferWithdrawal = do
  parties@Test_Parties{..} <- test_setup
  buyer <- allocateParty "Buyer"
  
  debug "=== Testing Offer Withdrawal ==="
  
  now <- getTime
  
  offerCid <- submit buyer do
    createCmd LoanOffer with
      offerId = "OFFER-001"
      listingId = "LISTING-006"
      seller = alice
      buyer
      loanId = "LOAN-008"
      offerPrice = 45000.0
      offerExpiresAt = addRelTime now (days 3)
      status = OfferPending
  
