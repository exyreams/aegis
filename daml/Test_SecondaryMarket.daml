-- TRANSFER AND SETTLEMENT TESTS
-- | Test transfer and settlement templates
testTransferAndSettlement : Script ()
testTransferAndSettlement = do
  parties@Test_Parties{..} <- test_setup
  buyer <- allocateParty "TransferBuyer"
  
  debug "=== Testing Transfer and Settlement Templates ==="
  
  now <- getTime
  
  -- Create SecondaryLoanTransfer template
  transferCid <- submitMulti [alice, buyer] [] do
    createCmd SecondaryLoanTransfer with
      transferId = "TRANSFER-001"
      seller = alice
      buyer
      borrower = bob
      loanId = "LOAN-TRANSFER-001"
      transferPrice = 82000.0
      outstandingPrincipal = 80000.0
      interestRate = 0.08
      maturityDate = addRelTime now (days 90)
      collateralValue = 120000.0
      initiatedAt = now
      status = TransferPending
  
  debug "Transfer template created"
  
  -- Create TransferSettlement template
  settlementCid <- submitMulti [alice, buyer] [] do
    createCmd TransferSettlement with
      settlementId = "SETTLE-001"
      seller = alice
      buyer
      borrower = bob
      loanId = "LOAN-TRANSFER-001"
      transferPrice = 82000.0
      transferFee = 1000.0
      netProceeds = 81000.0
      settledAt = now
  
  debug "Settlement template created"
  
  debug "=== Transfer and Settlement Test Completed ==="



