  debug "=== Testing SubstitutionRequest Creation ==="
  
  now <- getTime
  
  let originalAsset = CollateralAsset with
        assetId = "ETH-SUB-SIMPLE"
        assetType = Cryptocurrency "ETH"
        quantity = 50.0
        currentValue = 75000.0
        initialValue = 75000.0
        volatilityScore = 0.35
        liquidityRating = HighlyLiquid
        lastValuationTime = now
        valuationSource = "Chainlink"
        haircut = 0.20
  
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-SUB-SIMPLE"
      borrower = alice
      lender
      loanId = "LOAN-SUB-SIMPLE"
      assets = [originalAsset]
      collateralRequirements = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH", Cryptocurrency "BTC"]
        maximumConcentration = 1.0
      totalInitialValue = 60000.0
      totalCurrentValue = 60000.0
      loanAmount = 40000.0
      currentLTV = Types.calculateLTV 40000.0 [originalAsset]
      status = CollateralHealthy
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  let newAsset = CollateralAsset with
        assetId = "BTC-SUB-SIMPLE"
        assetType = Cryptocurrency "BTC"
        quantity = 2.0
        currentValue = 80000.0
        initialValue = 80000.0
        volatilityScore = 0.40
        liquidityRating = HighlyLiquid
        lastValuationTime = now
        valuationSource = "Coinbase"
        haircut = 0.25
  
  -- Create SubstitutionRequest
  requestCid <- submit alice do
    exerciseCmd poolCid RequestSubstitution with
      assetToRemove = "ETH-SUB-SIMPLE"
      assetToAdd = newAsset
      reason = "Prefer BTC as collateral"
  
  debug "SubstitutionRequest created successfully"
  
  Some request <- queryContractId alice requestCid
  assertMsg "Request has correct asset to remove" (request.assetToRemove == "ETH-SUB-SIMPLE")
  
  debug "=== SubstitutionRequest Creation Test Completed ==="


-- AEGIS PLATFORM INTEGRATION TESTS
-- | Test liquidation with Aegis platform reimbursement for shortfall
testLiquidationWithAegisReimbursement : Script ()
testLiquidationWithAegisReimbursement = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "AegisLender"
  platform <- allocateParty "AegisPlatform"
  emergencyOp <- allocateParty "EmergencyOp"
  complianceOff <- allocateParty "ComplianceOff"
  
  debug "=== Testing Liquidation with Aegis Reimbursement ==="
  
  now <- getTime
  
  -- Initialize Aegis platform with funds
  let initialTreasury = AegisTreasury with
        treasuryBalances = [(Stablecoin "USDC", 10000000.0)]
        reserveRatio = 0.15
        lastAuditDate = now
  
  platformCid <- submitMulti [platform, emergencyOp, complianceOff] [] do
    createCmd Aegis.AegisPlatform with
      platform
      treasury = initialTreasury
      authorizedAssets = [Stablecoin "USDC"]
      platformFeeRate = 0.005
      emergencyOperator = emergencyOp
      complianceOfficer = complianceOff
      totalLoansOriginated = 0.0
      totalFeesCollected = 0.0
      activeLenders = [lender]
      platformStatus = PlatformActive
  
  debug "Aegis platform initialized"
  
  -- Create collateral pool below liquidation threshold
  let collateralAssets = 
        [ CollateralAsset with
            assetId = "ETH-AEGIS-001"
            assetType = Cryptocurrency "ETH"
            quantity = 20.0
            currentValue = 25000.0
            initialValue = 40000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  let collateralReqs = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH"]
        maximumConcentration = 1.0
  
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-AEGIS-001"
      borrower = alice
      lender
      loanId = "LOAN-AEGIS-001"
      assets = collateralAssets
      collateralRequirements = collateralReqs
      totalInitialValue = 40000.0
      totalCurrentValue = 25000.0
      loanAmount = 30000.0
      currentLTV = 1.2
      status = CollateralUnderliquidation
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  debug "Collateral pool created below liquidation threshold"
  
  -- Initiate liquidation
  liquidationCid <- submit lender do
    exerciseCmd poolCid InitiateLiquidation with
      reason = "Collateral value fell below liquidation threshold"
  
  debug "Liquidation initiated"
  
  -- Execute liquidation with shortfall (proceeds < loan amount)
  -- Platform needs to be involved for reimbursement
  (settlementCid, reimbursementResult) <- submitMulti [lender, platform] [] do
    exerciseCmd liquidationCid ExecuteLiquidation with
      liquidationProceeds = 24000.0
      liquidationCosts = 1000.0
      platformCid = Some platformCid
      assetType = Stablecoin "USDC"
  
  debug "Liquidation executed with platform reimbursement"
  
  Some settlement <- queryContractId lender settlementCid
  assertMsg "Settlement has shortfall" (settlement.shortfall == 7000.0)
  assertMsg "Net proceeds calculated" (settlement.netProceeds == 23000.0)
  
  -- Verify platform reimbursed lender
  case reimbursementResult of
    Some (newPlatformCid, balanceCid) -> do
      Some balance <- queryContractId lender balanceCid
      assertMsg "Lender received reimbursement" (balance.totalBalance >= 7000.0)
      debug "✓ Platform successfully reimbursed lender for shortfall"
    None -> abort "Expected platform reimbursement"
  
  debug "=== Liquidation with Aegis Reimbursement Test Completed ==="

-- | Test margin call with Aegis emergency liquidity support
testMarginCallWithAegisSupport : Script ()
