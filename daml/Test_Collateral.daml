-- | Comprehensive tests for Collateral Management System
-- Tests collateral pools, margin calls, liquidation, and substitution

module Test_Collateral where

import Daml.Script
import DA.Time
import Test_Setup
import Types
import Collateral
import qualified Aegis


-- COLLATERAL POOL TESTS
-- | Test creating and managing a collateral pool
testCollateralPoolCreation : Script ()
testCollateralPoolCreation = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "Lender"
  
  debug "=== Testing Collateral Pool Creation ==="
  
  now <- getTime
  
  let collateralAssets = 
        [ CollateralAsset with
            assetId = "ETH-001"
            assetType = Cryptocurrency "ETH"
            quantity = 100.0
            currentValue = 150000.0
            initialValue = 150000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        , CollateralAsset with
            assetId = "BTC-001"
            assetType = Cryptocurrency "BTC"
            quantity = 2.0
            currentValue = 80000.0
            initialValue = 80000.0
            volatilityScore = 0.40
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Coinbase"
            haircut = 0.25
        ]
  
  let collateralReqs = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH", Cryptocurrency "BTC"]
        maximumConcentration = 0.6
  
  let totalValue = Types.calculateCollateralValue collateralAssets
  let loanAmount = 100000.0
  let ltv = Types.calculateLTV loanAmount collateralAssets
  
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-001"
      borrower = alice
      lender
      loanId = "LOAN-001"
      assets = collateralAssets
      collateralRequirements = collateralReqs
      totalInitialValue = totalValue
      totalCurrentValue = totalValue
      loanAmount
      currentLTV = ltv
      status = CollateralHealthy
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  debug "Collateral pool created successfully"
  
  Some pool <- queryContractId alice poolCid
  assertMsg "Pool has correct number of assets" (length pool.assets == 2)
  assertMsg "Pool status is healthy" (pool.status == CollateralHealthy)
  
  debug "=== Collateral Pool Creation Test Completed ==="

-- | Test collateral valuation updates
testCollateralValuation : Script ()
testCollateralValuation = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "Lender"
  
  debug "=== Testing Collateral Valuation Updates ==="
  
  now <- getTime
  
  let collateralAssets = 
        [ CollateralAsset with
            assetId = "ETH-002"
            assetType = Cryptocurrency "ETH"
            quantity = 50.0
            currentValue = 75000.0
            initialValue = 75000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  let collateralReqs = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH"]
        maximumConcentration = 1.0
  
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-002"
      borrower = alice
      lender
      loanId = "LOAN-002"
      assets = collateralAssets
      collateralRequirements = collateralReqs
      totalInitialValue = 75000.0
      totalCurrentValue = 75000.0
      loanAmount = 50000.0
      currentLTV = 0.67
      status = CollateralHealthy
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  debug "Initial pool created with ETH at $1500/ETH"
  
  -- Simulate price drop to $1200/ETH
  poolCid <- submit lender do
    exerciseCmd poolCid UpdateValuation with
      newAssetValues = [("ETH-002", 1200.0)]
      valuationSource = "Chainlink-Updated"
  
  debug "Valuation updated - ETH dropped to $1200/ETH"
  
  Some pool <- queryContractId alice poolCid
  assertMsg "Valuation was updated" (pool.totalCurrentValue < 75000.0)
  assertMsg "LTV increased" (pool.currentLTV > 0.67)
  
  debug "=== Collateral Valuation Test Completed ==="

-- | Test margin call trigger and response
testMarginCall : Script ()
testMarginCall = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "Lender"
  
  debug "=== Testing Margin Call Mechanism ==="
  
  now <- getTime
  
  let collateralAssets = 
        [ CollateralAsset with
            assetId = "ETH-003"
            assetType = Cryptocurrency "ETH"
            quantity = 40.0
            currentValue = 60000.0
            initialValue = 80000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  let collateralReqs = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH"]
        maximumConcentration = 1.0
  
  -- Create pool with collateral below maintenance ratio
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-003"
      borrower = alice
      lender
      loanId = "LOAN-003"
      assets = collateralAssets
      collateralRequirements = collateralReqs
      totalInitialValue = 80000.0
      totalCurrentValue = 60000.0
      loanAmount = 50000.0
      currentLTV = 0.83
      status = CollateralMarginCall
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  debug "Pool created with collateral below maintenance ratio"
  
  -- Trigger margin call
  let deadline = addRelTime now (days 3)
  poolCid <- submit lender do
    exerciseCmd poolCid TriggerMarginCall with
      deadline
      requiredAmount = 15000.0
  
  debug "Margin call triggered with 3-day deadline"
  
  Some pool <- queryContractId alice poolCid
  assertMsg "Margin call is active" pool.marginCallActive
  assertMsg "Status is margin call" (pool.status == CollateralMarginCall)
  
  -- Borrower responds by adding more collateral
  let additionalAsset = CollateralAsset with
        assetId = "ETH-004"
        assetType = Cryptocurrency "ETH"
        quantity = 15.0
        currentValue = 22500.0
        initialValue = 22500.0
        volatilityScore = 0.35
        liquidityRating = HighlyLiquid
        lastValuationTime = now
        valuationSource = "Chainlink"
        haircut = 0.20
  
  poolCid <- submit alice do
    exerciseCmd poolCid RespondToMarginCall with
      additionalAssets = [additionalAsset]
  
  debug "Borrower added additional collateral"
  
  Some finalPool <- queryContractId alice poolCid
  assertMsg "Margin call satisfied" (not finalPool.marginCallActive)
  assertMsg "Status returned to healthy" (finalPool.status == CollateralHealthy)
  assertMsg "Pool has more assets" (length finalPool.assets > length collateralAssets)
  
  debug "=== Margin Call Test Completed ==="

-- | Test collateral liquidation process
testCollateralLiquidation : Script ()
testCollateralLiquidation = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "Lender"
  
  debug "=== Testing Collateral Liquidation ==="
  
  now <- getTime
  
  let collateralAssets = 
        [ CollateralAsset with
            assetId = "ETH-005"
            assetType = Cryptocurrency "ETH"
            quantity = 30.0
            currentValue = 40000.0
            initialValue = 60000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  let collateralReqs = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH"]
        maximumConcentration = 1.0
  
  -- Create pool with collateral below liquidation ratio
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-004"
      borrower = alice
      lender
      loanId = "LOAN-004"
      assets = collateralAssets
      collateralRequirements = collateralReqs
      totalInitialValue = 60000.0
      totalCurrentValue = 40000.0
      loanAmount = 38000.0
      currentLTV = 0.95
      status = CollateralUnderliquidation
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  debug "Pool created with collateral below liquidation threshold"
  
  -- Initiate liquidation
  liquidationCid <- submit lender do
    exerciseCmd poolCid InitiateLiquidation with
      reason = "Collateral value fell below liquidation threshold"
  
  debug "Liquidation initiated"
  
  Some liquidation <- queryContractId lender liquidationCid
  assertMsg "Liquidation status is pending" (liquidation.status == LiquidationPending)
  
  -- Execute liquidation (without platform integration)
  (settlementCid, _) <- submit lender do
    exerciseCmd liquidationCid ExecuteLiquidation with
      liquidationProceeds = 38000.0
      liquidationCosts = 2000.0
      platformCid = None
      assetType = Stablecoin "USDC"
  
  debug "Liquidation executed"
  
  Some settlement <- queryContractId lender settlementCid
  assertMsg "Net proceeds calculated correctly" (settlement.netProceeds == 36000.0)
  assertMsg "Shortfall calculated" (settlement.shortfall == 2000.0)
  
  debug "=== Collateral Liquidation Test Completed ==="

-- | Test collateral substitution
testCollateralSubstitution : Script ()
testCollateralSubstitution = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "Lender"
  
  debug "=== Testing Collateral Substitution ==="
  
  now <- getTime
  
  let originalAsset = CollateralAsset with
        assetId = "ETH-006"
        assetType = Cryptocurrency "ETH"
        quantity = 50.0
        currentValue = 75000.0
        initialValue = 75000.0
        volatilityScore = 0.35
        liquidityRating = HighlyLiquid
        lastValuationTime = now
        valuationSource = "Chainlink"
        haircut = 0.20
  
  let collateralReqs = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH", Cryptocurrency "BTC"]
        maximumConcentration = 1.0
  
  let totalValue = Types.calculateCollateralValue [originalAsset]
  
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-005"
      borrower = alice
      lender
      loanId = "LOAN-005"
      assets = [originalAsset]
      collateralRequirements = collateralReqs
      totalInitialValue = totalValue
      totalCurrentValue = totalValue
      loanAmount = 40000.0
      currentLTV = Types.calculateLTV 40000.0 [originalAsset]
      status = CollateralHealthy
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  debug "Pool created with ETH collateral"
  
  -- Request substitution to BTC
  let newAsset = CollateralAsset with
        assetId = "BTC-002"
        assetType = Cryptocurrency "BTC"
        quantity = 2.0
        currentValue = 80000.0
        initialValue = 80000.0
        volatilityScore = 0.40
        liquidityRating = HighlyLiquid
        lastValuationTime = now
        valuationSource = "Coinbase"
        haircut = 0.25
  
  requestCid <- submit alice do
    exerciseCmd poolCid RequestSubstitution with
      assetToRemove = "ETH-006"
      assetToAdd = newAsset
      reason = "Prefer BTC as collateral"
  
  debug "Substitution request created"
  
  -- Lender approves substitution
  newPoolCid <- submit lender do
    exerciseCmd requestCid ApproveSubstitution
  
  debug "Substitution approved"
  
  Some newPool <- queryContractId alice newPoolCid
  assertMsg "Asset was substituted" (any (\a -> a.assetId == "BTC-002") newPool.assets)
  assertMsg "Old asset removed" (not (any (\a -> a.assetId == "ETH-006") newPool.assets))
  
  debug "=== Collateral Substitution Test Completed ==="

-- | Test partial collateral release
testPartialCollateralRelease : Script ()
testPartialCollateralRelease = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "Lender"
  
  debug "=== Testing Partial Collateral Release ==="
  
  now <- getTime
  
  let assets = 
        [ CollateralAsset with
            assetId = "ETH-007"
            assetType = Cryptocurrency "ETH"
            quantity = 200.0
            currentValue = 300000.0
            initialValue = 300000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        , CollateralAsset with
            assetId = "BTC-003"
            assetType = Cryptocurrency "BTC"
            quantity = 2.0
            currentValue = 80000.0
            initialValue = 80000.0
            volatilityScore = 0.40
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Coinbase"
            haircut = 0.25
        ]
  
  let collateralReqs = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH", Cryptocurrency "BTC"]
        maximumConcentration = 0.8
  
  let totalValue = Types.calculateCollateralValue assets
  
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-006"
      borrower = alice
      lender
      loanId = "LOAN-006"
      assets
      collateralRequirements = collateralReqs
      totalInitialValue = totalValue
      totalCurrentValue = totalValue
      loanAmount = 100000.0
      currentLTV = Types.calculateLTV 100000.0 assets
      status = CollateralHealthy
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  debug "Pool created with over-collateralization"
  
  -- Release one asset (BTC)
  newPoolCid <- submitMulti [alice, lender] [] do
    exerciseCmd poolCid PartialRelease with
      assetIdsToRelease = ["BTC-003"]
  
  debug "Partial collateral released"
  
  Some newPool <- queryContractId alice newPoolCid
  assertMsg "Asset was released" (length newPool.assets == 1)
  assertMsg "Remaining collateral still meets requirements" 
    (newPool.currentLTV <= (1.0 / collateralReqs.minimumRatio))
  
  debug "=== Partial Collateral Release Test Completed ==="

