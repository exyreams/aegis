  -- Initialize Aegis platform
  let initialTreasury = AegisTreasury with
        treasuryBalances = [(Stablecoin "USDC", 5000000.0)]
        reserveRatio = 0.15
        lastAuditDate = now
  
  platformCid <- submitMulti [platform, emergencyOp, complianceOff] [] do
    createCmd Aegis.AegisPlatform with
      platform
      treasury = initialTreasury
      authorizedAssets = [Stablecoin "USDC"]
      platformFeeRate = 0.005
      emergencyOperator = emergencyOp
      complianceOfficer = complianceOff
      totalLoansOriginated = 0.0
      totalFeesCollected = 0.0
      activeLenders = [lender]
      platformStatus = PlatformActive
  
  debug "Aegis platform initialized"
  
  -- Create collateral pool with active margin call
  let collateralAssets = 
        [ CollateralAsset with
            assetId = "ETH-AEGIS-002"
            assetType = Cryptocurrency "ETH"
            quantity = 30.0
            currentValue = 42000.0
            initialValue = 60000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  let collateralReqs = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH"]
        maximumConcentration = 1.0
  
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-AEGIS-002"
      borrower = alice
      lender
      loanId = "LOAN-AEGIS-002"
      assets = collateralAssets
      collateralRequirements = collateralReqs
      totalInitialValue = 60000.0
      totalCurrentValue = 42000.0
      loanAmount = 35000.0
      currentLTV = 0.83
      status = CollateralMarginCall
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  debug "Collateral pool created below maintenance ratio"
  
  -- Trigger margin call
  let deadline = addRelTime now (days 2)
  poolCid <- submit lender do
    exerciseCmd poolCid TriggerMarginCall with
      deadline
      requiredAmount = 10000.0
  
  debug "Margin call triggered"
  
  -- Request emergency liquidity support from Aegis
  let supportTerms = LiquiditySupportTerms with
        interestRate = 0.05
        repaymentDeadline = addRelTime now (days 90)
        collateralRequired = False
  
  (newPoolCid, newPlatformCid, balanceCid) <- submit lender do
    exerciseCmd poolCid RequestEmergencySupport with
      platformCid
      supportAmount = 10000.0
      assetType = Stablecoin "USDC"
      repaymentTerms = supportTerms
  
  debug "Emergency liquidity support provided by Aegis"
  
  Some newPool <- queryContractId alice newPoolCid
  assertMsg "Margin call resolved" (not newPool.marginCallActive)
  assertMsg "Pool status healthy" (newPool.status == CollateralHealthy)
  
  Some balance <- queryContractId lender balanceCid
  assertMsg "Lender received liquidity support" (balance.totalBalance >= 10000.0)
  
  debug "=== Margin Call with Aegis Support Test Completed ==="

-- | Test collateral monitoring workflow with Aegis integration
testCollateralMonitoringWithAegis : Script ()
testCollateralMonitoringWithAegis = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "MonitorLender"
  
  debug "=== Testing Collateral Monitoring Workflow ==="
  
  now <- getTime
  
  let collateralAssets = 
        [ CollateralAsset with
            assetId = "ETH-MONITOR"
            assetType = Cryptocurrency "ETH"
            quantity = 100.0
            currentValue = 150000.0
            initialValue = 150000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  let collateralReqs = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH"]
        maximumConcentration = 1.0
  
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-MONITOR"
      borrower = alice
      lender
      loanId = "LOAN-MONITOR"
      assets = collateralAssets
      collateralRequirements = collateralReqs
      totalInitialValue = 150000.0
      totalCurrentValue = 150000.0
      loanAmount = 100000.0
      currentLTV = Types.calculateLTV 100000.0 collateralAssets
      status = CollateralHealthy
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  debug "Initial pool created with healthy collateral"
  
  -- Simulate price drop that triggers margin call
  newPoolCid <- submit lender do
    exerciseCmd poolCid UpdateValuation with
      newAssetValues = [("ETH-MONITOR", 1100.0)]
      valuationSource = "Chainlink-Updated"
  
  debug "Collateral health monitored and updated"
  
  Some monitoredPool <- queryContractId alice newPoolCid
  assertMsg "Valuation was updated" (monitoredPool.totalCurrentValue < 150000.0)
  
  if monitoredPool.marginCallActive
    then debug "Margin call was automatically triggered"
    else debug "Collateral remains healthy"
  
  debug "=== Collateral Monitoring Test Completed ==="

-- | Run all collateral tests
runAllCollateralTests : Script ()
runAllCollateralTests = do
  testCollateralPoolCreation
  testCollateralValuation
  testMarginCall
  testCollateralLiquidation
  -- testCollateralSubstitution  -- TODO: Fix authorization issues
  testPartialCollateralRelease
  testCollateralRelease
  testCancelLiquidation
  testCreateSubstitutionRequest
  -- testArchiveCollateralPool  -- TODO: Fix authorization issues
  testAcknowledgeCollateralSettlement
  -- testLiquidationWithAegisReimbursement  -- TODO: Workflow needs redesign - lender can't exercise platform choice
  -- testMarginCallWithAegisSupport  -- TODO: Workflow needs redesign - lender can't exercise platform choice
  testCollateralMonitoringWithAegis
  debug "=== All Collateral Tests Completed Successfully ==="



-- MISSING CHOICE TESTS
-- | Test RejectSubstitution choice
testRejectSubstitution : Script ()
testRejectSubstitution = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "RejectLender"
  
  now <- getTime
  
  let asset = CollateralAsset with
        assetId = "ETH-REJECT"
        assetType = Cryptocurrency "ETH"
        quantity = 50.0
        currentValue = 75000.0
        initialValue = 75000.0
        volatilityScore = 0.35
        liquidityRating = HighlyLiquid
        lastValuationTime = now
        valuationSource = "Chainlink"
        haircut = 0.20
  
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-REJECT"
      borrower = alice
      lender
      loanId = "LOAN-REJECT"
      assets = [asset]
      collateralRequirements = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH", Cryptocurrency "BTC"]
        maximumConcentration = 1.0
      totalInitialValue = 60000.0
      totalCurrentValue = 60000.0
      loanAmount = 40000.0
      currentLTV = Types.calculateLTV 40000.0 [asset]
      status = CollateralHealthy
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  let newAsset = CollateralAsset with
        assetId = "BTC-REJECT"
        assetType = Cryptocurrency "BTC"
        quantity = 2.0
        currentValue = 80000.0
        initialValue = 80000.0
        volatilityScore = 0.40
        liquidityRating = HighlyLiquid
        lastValuationTime = now
        valuationSource = "Coinbase"
        haircut = 0.25
  
  requestCid <- submit alice do
    exerciseCmd poolCid RequestSubstitution with
      assetToRemove = "ETH-REJECT"
      assetToAdd = newAsset
      reason = "Switch to BTC"
  
  submit lender do
    exerciseCmd requestCid RejectSubstitution with
      rejectionReason = "Not approved"


-- | Test Archive choices
testCollateralArchives : Script ()
testCollateralArchives = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "ArchLender"
  
  now <- getTime
  
  -- Archive SubstitutionRequest
  let asset = CollateralAsset with
        assetId = "ETH-ARCH"
        assetType = Cryptocurrency "ETH"
        quantity = 50.0
        currentValue = 75000.0
        initialValue = 75000.0
        volatilityScore = 0.35
        liquidityRating = HighlyLiquid
        lastValuationTime = now
        valuationSource = "Chainlink"
        haircut = 0.20
  
  poolCid <- submitMulti [alice, lender] [] do
    createCmd CollateralPool with
      poolId = "POOL-ARCH"
      borrower = alice
      lender
      loanId = "LOAN-ARCH"
      assets = [asset]
      collateralRequirements = CollateralRequirements with
        minimumRatio = 1.5
        maintenanceRatio = 1.3
        liquidationRatio = 1.1
        acceptedAssetTypes = [Cryptocurrency "ETH"]
        maximumConcentration = 1.0
      totalInitialValue = 60000.0
      totalCurrentValue = 60000.0
      loanAmount = 40000.0
      currentLTV = Types.calculateLTV 40000.0 [asset]
      status = CollateralHealthy
      lastValuationTime = now
      marginCallActive = False
      marginCallDeadline = None
  
  requestCid <- submit alice do
    exerciseCmd poolCid RequestSubstitution with
      assetToRemove = "ETH-ARCH"
      assetToAdd = asset
      reason = "Test"
  
  submit alice do
    archiveCmd requestCid
  
  -- Archive LiquidationSettlement
  settlementCid <- submit lender do
    createCmd LiquidationSettlement with
      settlementId = "SETTLE-ARCH"
      borrower = alice
      lender
      loanId = "LOAN-ARCH"
      liquidationProceeds = 50000.0
      liquidationCosts = 2000.0
      netProceeds = 48000.0
      loanAmount = 50000.0
      surplus = 0.0
      shortfall = 2000.0
      settledAt = now
  
  submit lender do
    archiveCmd settlementCid
  
  -- Archive CollateralLiquidation
  liquidationCid <- submit lender do
    createCmd CollateralLiquidation with
      liquidationId = "LIQ-ARCH"
      borrower = alice
      lender
      loanId = "LOAN-ARCH"
      assets = [asset]
      totalValue = 40000.0
      loanAmount = 50000.0
      reason = "Test"
      initiatedAt = now
      status = LiquidationPending
  
  submit lender do
    archiveCmd liquidationCid
  
  return ()


