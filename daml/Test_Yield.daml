-- | Test complete liquidity pool workflow
testCompleteLiquidityPoolWorkflow : Script ()
testCompleteLiquidityPoolWorkflow = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "PoolMgr"
  
  now <- getTime
  
  -- Create pool
  poolCid <- submit poolManager do
    createCmd LiquidityPool with
      poolId = "POOL-WORKFLOW"
      poolManager
      poolName = "Workflow Pool"
      poolStrategy = YieldStrategy with
        strategyType = DirectLending
        riskTolerance = Moderate
        targetYield = 0.08
        maximumDrawdown = 0.15
        rebalanceThreshold = 0.05
        compoundingEnabled = True
        liquidityReserve = 0.10
      participants = []
      totalLiquidity = 0.0
      totalLPTokens = 0.0
      activeLoans = []
      totalDeployed = 0.0
      totalYieldEarned = 0.0
      performanceMetrics = PoolPerformanceMetrics with
        currentAPY = 0.0
        totalReturn = 0.0
        sharpeRatio = 0.0
        volatility = 0.0
        maxDrawdown = 0.0
        utilizationRate = 0.0
      createdAt = now
      lastRebalanceDate = now
  
  -- Test JoinPool
  poolCid <- submit alice do
    exerciseCmd poolCid JoinPool with
      participant = alice
      contributionAmount = 100000.0
  
  poolCid <- submit bob do
    exerciseCmd poolCid JoinPool with
      participant = bob
      contributionAmount = 50000.0
  
  -- Test DeployLiquidity
  poolCid <- submit poolManager do
    exerciseCmd poolCid DeployLiquidity with
      loanId = "LOAN-DEPLOY1"
      amount = 75000.0
  
  -- Test ReceiveRepayment
  poolCid <- submit poolManager do
    exerciseCmd poolCid ReceiveRepayment with
      loanId = "LOAN-DEPLOY1"
      principalAmount = 75000.0
      interestAmount = 6000.0
  
  -- Test UpdatePerformanceMetrics
  poolCid <- submit poolManager do
    exerciseCmd poolCid UpdatePerformanceMetrics with
      newMetrics = PoolPerformanceMetrics with
        currentAPY = 0.08
        totalReturn = 0.04
        sharpeRatio = 1.5
        volatility = 0.10
        maxDrawdown = 0.05
        utilizationRate = 0.50
  
  -- Test RebalancePool
  poolCid <- submit poolManager do
    exerciseCmd poolCid RebalancePool with
      newStrategy = YieldStrategy with
        strategyType = HybridStrategy
        riskTolerance = Aggressive
        targetYield = 0.10
        maximumDrawdown = 0.20
        rebalanceThreshold = 0.05
        compoundingEnabled = True
        liquidityReserve = 0.10
  
  return ()

-- | Test LP Token operations (additional test)
testLPTokenOperations2 : Script ()
testLPTokenOperations2 = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "TokenMgr"
  
  now <- getTime
  
  -- Create LP token
  tokenCid <- submitMulti [alice, poolManager] [] do
    createCmd LPToken with
      tokenId = "LP-OPS"
      poolId = "POOL-OPS"
      owner = alice
      amount = 1000.0
      poolManager
  
  -- Test TransferLPToken
  tokenCid <- submitMulti [alice, bob, poolManager] [] do
    exerciseCmd tokenCid TransferLPToken with
      newOwner = bob
  
  -- Test SplitLPToken
  tokenCids <- submitMulti [bob, poolManager] [] do
    exerciseCmd tokenCid SplitLPToken with
      amounts = [400.0, 300.0, 300.0]
  
  return ()

-- | Test Performance Bonus operations
testPerformanceBonusOperations : Script ()
testPerformanceBonusOperations = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "BonusMgr"
  
  now <- getTime
  
  -- Create performance bonus
  bonusCid <- submitMulti [alice, poolManager] [] do
    createCmd PerformanceBonus with
      bonusId = "BONUS-OPS"
      poolId = "POOL-OPS"
      poolManager
      participants = [(alice, 5000.0), (bob, 3000.0)]
      totalBonusPool = 8000.0
      performancePeriodStart = now
      performancePeriodEnd = addRelTime now (days 30)
      distributed = False
  
  -- Test ClaimBonus
  aliceBonus <- submitMulti [alice, poolManager] [] do
    exerciseCmd bonusCid ClaimBonus with
      participant = alice
  
  -- Test MarkDistributed
  bonusCid <- submit poolManager do
    exerciseCmd bonusCid MarkDistributed
  
  return ()
