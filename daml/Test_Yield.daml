-- | Comprehensive tests for Yield Generation and Liquidity Pool System
-- Tests liquidity pools, LP tokens, yield optimization, and staking

module Test_Yield where

import Daml.Script
import DA.Time
import DA.List (head)
import Test_Setup
import Types
import Yield

-- LIQUIDITY POOL TESTS
-- | Test creating a liquidity pool
testLiquidityPoolCreation : Script ()
testLiquidityPoolCreation = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "PoolManager"
  
  debug "=== Testing Liquidity Pool Creation ==="
  
  now <- getTime
  
  let strategy = YieldStrategy with
        strategyType = PoolParticipation
        riskTolerance = Moderate
        targetYield = 0.08
        maximumDrawdown = 0.15
        rebalanceThreshold = 0.05
        compoundingEnabled = True
        liquidityReserve = 0.10
  
  let performanceMetrics = PoolPerformanceMetrics with
        currentAPY = 0.0
        totalReturn = 0.0
        sharpeRatio = 0.0
        volatility = 0.0
        maxDrawdown = 0.0
        utilizationRate = 0.0
  
  poolCid <- submit poolManager do
    createCmd LiquidityPool with
      poolId = "POOL-001"
      poolManager
      poolName = "Conservative Lending Pool"
      poolStrategy = strategy
      participants = []
      totalLiquidity = 0.0
      totalLPTokens = 0.0
      activeLoans = []
      totalDeployed = 0.0
      totalYieldEarned = 0.0
      performanceMetrics
      createdAt = now
      lastRebalanceDate = now
  
  debug "Liquidity pool created successfully"
  
  Some pool <- queryContractId poolManager poolCid
  assertMsg "Pool has correct strategy" (pool.poolStrategy.strategyType == PoolParticipation)
  assertMsg "Pool starts with zero liquidity" (pool.totalLiquidity == 0.0)
  
  debug "=== Liquidity Pool Creation Test Completed ==="

-- | Test joining a liquidity pool
testJoinPool : Script ()
testJoinPool = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "PoolManager"
  
  debug "=== Testing Pool Participation ==="
  
  now <- getTime
  
  let strategy = YieldStrategy with
        strategyType = DirectLending
        riskTolerance = Aggressive
        targetYield = 0.12
        maximumDrawdown = 0.25
        rebalanceThreshold = 0.10
        compoundingEnabled = True
        liquidityReserve = 0.05
  
  let performanceMetrics = PoolPerformanceMetrics with
        currentAPY = 0.0
        totalReturn = 0.0
        sharpeRatio = 0.0
        volatility = 0.0
        maxDrawdown = 0.0
        utilizationRate = 0.0
  
  poolCid <- submit poolManager do
    createCmd LiquidityPool with
      poolId = "POOL-002"
      poolManager
      poolName = "Aggressive Yield Pool"
      poolStrategy = strategy
      participants = []
      totalLiquidity = 0.0
      totalLPTokens = 0.0
      activeLoans = []
      totalDeployed = 0.0
      totalYieldEarned = 0.0
      performanceMetrics
      createdAt = now
      lastRebalanceDate = now
  
  debug "Pool created"
  
  -- Alice joins the pool
  poolCid <- submit alice do
    exerciseCmd poolCid JoinPool with
      participant = alice
      contributionAmount = 100000.0
  
  debug "Alice joined pool with $100,000"
  
  Some pool <- queryContractId poolManager poolCid
  assertMsg "Pool has liquidity" (pool.totalLiquidity == 100000.0)
  assertMsg "LP tokens issued" (pool.totalLPTokens == 100000.0)
  assertMsg "Alice is participant" (length pool.participants == 1)
  
  -- Bob joins the pool
  poolCid <- submit bob do
    exerciseCmd poolCid JoinPool with
      participant = bob
      contributionAmount = 50000.0
  
  debug "Bob joined pool with $50,000"
  
  Some finalPool <- queryContractId poolManager poolCid
  assertMsg "Total liquidity increased" (finalPool.totalLiquidity == 150000.0)
  assertMsg "Multiple participants" (length finalPool.participants == 2)
  
  debug "=== Pool Participation Test Completed ==="

-- | Test withdrawing from pool
testWithdrawFromPool : Script ()
testWithdrawFromPool = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "PoolManager"
  
  debug "=== Testing Pool Withdrawal ==="
  
  now <- getTime
  
  let participant = PoolParticipant with
        participant = alice
        contribution = 100000.0
        lpTokens = 100000.0
        joinedAt = now
        lastRewardClaim = now
        accumulatedYield = 0.0
  
  let strategy = YieldStrategy with
        strategyType = HybridStrategy
        riskTolerance = Moderate
        targetYield = 0.10
        maximumDrawdown = 0.20
        rebalanceThreshold = 0.08
        compoundingEnabled = False
        liquidityReserve = 0.15
  
  let performanceMetrics = PoolPerformanceMetrics with
        currentAPY = 0.08
        totalReturn = 0.05
        sharpeRatio = 1.2
        volatility = 0.12
        maxDrawdown = 0.08
        utilizationRate = 0.50
  
  poolCid <- submit poolManager do
    createCmd LiquidityPool with
      poolId = "POOL-003"
      poolManager
      poolName = "Balanced Pool"
      poolStrategy = strategy
      participants = [participant]
      totalLiquidity = 100000.0
      totalLPTokens = 100000.0
      activeLoans = []
      totalDeployed = 0.0
      totalYieldEarned = 0.0
      performanceMetrics
      createdAt = now
      lastRebalanceDate = now
  
  debug "Pool with Alice's participation created"
  
  -- Alice withdraws half her position
  (poolCid, withdrawalAmount) <- submit alice do
    exerciseCmd poolCid WithdrawFromPool with
      participant = alice
      lpTokensToRedeem = 50000.0
  
  debug $ "Alice withdrew: $" <> show withdrawalAmount
  
  Some pool <- queryContractId poolManager poolCid
  assertMsg "Liquidity reduced" (pool.totalLiquidity == 50000.0)
  assertMsg "LP tokens burned" (pool.totalLPTokens == 50000.0)
  assertMsg "Withdrawal amount correct" (withdrawalAmount == 50000.0)
  
  debug "=== Pool Withdrawal Test Completed ==="

-- | Test yield distribution
testYieldDistribution : Script ()
testYieldDistribution = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "PoolManager"
  
  debug "=== Testing Yield Distribution ==="
  
  now <- getTime
  
  let participants = 
        [ PoolParticipant with
            participant = alice
            contribution = 60000.0
            lpTokens = 60000.0
            joinedAt = now
            lastRewardClaim = now
            accumulatedYield = 0.0
        , PoolParticipant with
            participant = bob
            contribution = 40000.0
            lpTokens = 40000.0
            joinedAt = now
            lastRewardClaim = now
            accumulatedYield = 0.0
        ]
  
  let strategy = YieldStrategy with
        strategyType = DirectLending
        riskTolerance = Conservative
        targetYield = 0.06
        maximumDrawdown = 0.10
        rebalanceThreshold = 0.05
        compoundingEnabled = True
        liquidityReserve = 0.20
  
  let performanceMetrics = PoolPerformanceMetrics with
        currentAPY = 0.06
        totalReturn = 0.03
        sharpeRatio = 1.5
        volatility = 0.08
        maxDrawdown = 0.05
        utilizationRate = 0.70
  
  poolCid <- submit poolManager do
    createCmd LiquidityPool with
      poolId = "POOL-004"
      poolManager
      poolName = "Conservative Pool"
      poolStrategy = strategy
      participants
      totalLiquidity = 100000.0
      totalLPTokens = 100000.0
      activeLoans = ["LOAN-001"]
      totalDeployed = 70000.0
      totalYieldEarned = 0.0
      performanceMetrics
      createdAt = now
      lastRebalanceDate = now
  
  debug "Pool with two participants created"
  
  -- Distribute yield
  poolCid <- submit poolManager do
    exerciseCmd poolCid DistributeYield with
      yieldAmount = 5000.0
      source = "Interest from LOAN-001"
  
  debug "Yield of $5,000 distributed"
  
  Some pool <- queryContractId poolManager poolCid
  assertMsg "Total yield earned updated" (pool.totalYieldEarned == 5000.0)
  
  -- Check Alice's share (60%)
  let aliceParticipant = head pool.participants
  assertMsg "Alice received proportional yield" (aliceParticipant.accumulatedYield == 3000.0)
  
  debug "=== Yield Distribution Test Completed ==="

-- | Test yield claiming
testClaimYield : Script ()
testClaimYield = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "PoolManager"
  
  debug "=== Testing Yield Claiming ==="
  
  now <- getTime
  
  let participant = PoolParticipant with
        participant = alice
        contribution = 100000.0
        lpTokens = 100000.0
        joinedAt = now
        lastRewardClaim = now
        accumulatedYield = 8000.0
  
  let strategy = YieldStrategy with
        strategyType = PoolParticipation
        riskTolerance = Moderate
        targetYield = 0.08
        maximumDrawdown = 0.15
        rebalanceThreshold = 0.07
        compoundingEnabled = False
        liquidityReserve = 0.10
  
  let performanceMetrics = PoolPerformanceMetrics with
        currentAPY = 0.08
        totalReturn = 0.08
        sharpeRatio = 1.3
        volatility = 0.10
        maxDrawdown = 0.06
        utilizationRate = 0.80
  
  poolCid <- submit poolManager do
    createCmd LiquidityPool with
      poolId = "POOL-005"
      poolManager
      poolName = "Yield Pool"
      poolStrategy = strategy
      participants = [participant]
      totalLiquidity = 100000.0
      totalLPTokens = 100000.0
      activeLoans = []
      totalDeployed = 80000.0
      totalYieldEarned = 8000.0
      performanceMetrics
      createdAt = now
      lastRebalanceDate = now
  
  debug "Pool with accumulated yield created"
  
  -- Alice claims her yield
  (poolCid, claimedAmount) <- submit alice do
    exerciseCmd poolCid ClaimYield with
      participant = alice
  
  debug $ "Alice claimed yield: $" <> show claimedAmount
  
  assertMsg "Claimed amount correct" (claimedAmount == 8000.0)
  
  Some pool <- queryContractId poolManager poolCid
  let aliceParticipant = head pool.participants
  assertMsg "Accumulated yield reset" (aliceParticipant.accumulatedYield == 0.0)
  
  debug "=== Yield Claiming Test Completed ==="

-- | Test yield reinvestment
testReinvestYield : Script ()
testReinvestYield = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "PoolManager"
  
  debug "=== Testing Yield Reinvestment ==="
  
  now <- getTime
  
  let participant = PoolParticipant with
        participant = alice
        contribution = 100000.0
        lpTokens = 100000.0
        joinedAt = now
        lastRewardClaim = now
        accumulatedYield = 10000.0
  
  let strategy = YieldStrategy with
        strategyType = HybridStrategy
        riskTolerance = Aggressive
        targetYield = 0.12
        maximumDrawdown = 0.25
        rebalanceThreshold = 0.10
        compoundingEnabled = True
        liquidityReserve = 0.05
  
  let performanceMetrics = PoolPerformanceMetrics with
        currentAPY = 0.12
        totalReturn = 0.10
        sharpeRatio = 1.1
        volatility = 0.15
        maxDrawdown = 0.10
        utilizationRate = 0.90
  
  poolCid <- submit poolManager do
    createCmd LiquidityPool with
      poolId = "POOL-006"
      poolManager
      poolName = "Compound Growth Pool"
      poolStrategy = strategy
      participants = [participant]
      totalLiquidity = 100000.0
      totalLPTokens = 100000.0
      activeLoans = []
      totalDeployed = 90000.0
      totalYieldEarned = 10000.0
      performanceMetrics
      createdAt = now
      lastRebalanceDate = now
  
  debug "Pool with accumulated yield created"
  
  -- Alice reinvests her yield
  poolCid <- submit alice do
    exerciseCmd poolCid ReinvestYield with
      participant = alice
  
  debug "Alice reinvested $10,000 yield"
  
  Some pool <- queryContractId poolManager poolCid
  assertMsg "Total liquidity increased" (pool.totalLiquidity == 110000.0)
  assertMsg "LP tokens increased" (pool.totalLPTokens > 100000.0)
  
  let aliceParticipant = head pool.participants
  assertMsg "Alice's contribution increased" (aliceParticipant.contribution == 110000.0)
  assertMsg "Accumulated yield reset" (aliceParticipant.accumulatedYield == 0.0)
  
  debug "=== Yield Reinvestment Test Completed ==="

