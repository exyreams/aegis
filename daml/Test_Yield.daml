-- LP TOKEN TESTS
-- | Test LP token operations
testLPTokenOperations : Script ()
testLPTokenOperations = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "TokenPoolManager"
  
  debug "=== Testing LP Token Operations ==="
  
  now <- getTime
  
  -- Create LP token
  tokenCid <- submit alice do
    createCmd LPToken with
      tokenId = "LP-TOKEN-001"
      poolId = "POOL-LP-001"
      owner = alice
      amount = 10000.0
      poolManager
  
  debug "LP token created"
  
  -- Transfer LP token
  newTokenCid <- submit alice do
    exerciseCmd tokenCid TransferLPToken with
      newOwner = bob
  
  debug "LP token transferred"
  
  -- Split LP token
  tokenCids <- submit bob do
    exerciseCmd newTokenCid SplitLPToken with
      amounts = [6000.0, 4000.0]
  
  debug "LP token split"
  
  debug "=== LP Token Operations Test Completed ==="


-- STAKING REWARDS TESTS
-- | Test staking rewards
testStakingRewards : Script ()
testStakingRewards = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "StakingPoolManager"
  
  debug "=== Testing Staking Rewards ==="
  
  now <- getTime
  
  -- Create staking rewards
  stakingCid <- submitMulti [alice, poolManager] [] do
    createCmd StakingRewards with
      stakingId = "STAKE-001"
      poolId = "POOL-STAKE-001"
      staker = alice
      poolManager
      stakedLPTokens = 50000.0
      stakingStartDate = now
      lockupPeriod = days 90
      rewardRate = 0.12
      accumulatedRewards = 0.0
  
  debug "Staking rewards created"
  
  -- Accrue rewards
  stakingCid <- submit poolManager do
    exerciseCmd stakingCid AccrueRewards with
      rewardAmount = 1500.0
  
  debug "Rewards accrued"
  
  -- Wait for lockup period
  passTime (days 91)
  
  -- Claim staking rewards
  (stakingCid, claimedAmount) <- submit alice do
    exerciseCmd stakingCid ClaimStakingRewards
  
  debug $ "Staking rewards claimed: " <> show claimedAmount
  
  -- Unstake
  unstakedAmount <- submit alice do
    exerciseCmd stakingCid Unstake
  
  debug $ "Unstaked successfully: " <> show unstakedAmount
  
  debug "=== Staking Rewards Test Completed ==="


-- PERFORMANCE BONUS TESTS
-- | Test performance bonus
testPerformanceBonus : Script ()
testPerformanceBonus = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "BonusPoolManager"
  
  debug "=== Testing Performance Bonus ==="
  
  now <- getTime
  
  let participants = 
        [ (alice, 5000.0)
        , (bob, 2500.0)
        ]
  
  bonusCid <- submit poolManager do
    createCmd PerformanceBonus with
      bonusId = "BONUS-001"
      poolId = "POOL-BONUS-001"
      poolManager
      participants
      totalBonusPool = 7500.0
      performancePeriodStart = now
      performancePeriodEnd = addRelTime now (days 30)
      distributed = False
  
  debug "Performance bonus created"
  
  -- Claim bonus
  claimedAmount <- submit alice do
    exerciseCmd bonusCid ClaimBonus with
      participant = alice
  
  debug $ "Bonus claimed by Alice: " <> show claimedAmount
  
  -- Mark as distributed
  bonusCid <- submit poolManager do
    exerciseCmd bonusCid MarkDistributed
  
  debug "Bonus marked as distributed"
  
  debug "=== Performance Bonus Test Completed ==="


-- YIELD OPTIMIZER TESTS
-- | Test yield optimizer
testYieldOptimizer : Script ()
testYieldOptimizer = do
  parties@Test_Parties{..} <- test_setup
  
  debug "=== Testing Yield Optimizer ==="
  
  now <- getTime
  
  let strategy = YieldStrategy with
        strategyType = HybridStrategy
        riskTolerance = Moderate
        targetYield = 0.10
        maximumDrawdown = 0.20
        rebalanceThreshold = 0.08
        compoundingEnabled = True
        liquidityReserve = 0.15
  
  optimizerCid <- submit alice do
    createCmd YieldOptimizer with
      optimizerId = "OPT-001"
      owner = alice
      strategy
      managedPools = []
      totalValue = 500000.0
      targetYield = 0.10
      riskTolerance = Moderate
      autoRebalance = True
      lastOptimizationDate = now
  
  debug "Yield optimizer created"
  
  -- Add managed pool
  optimizerCid <- submit alice do
    exerciseCmd optimizerCid AddManagedPool with
      poolId = "POOL-OPT-001"
  
  debug "Pool added to optimizer"
  
  -- Optimize yield
  optimizerCid <- submit alice do
    exerciseCmd optimizerCid OptimizeYield with
      newAllocations = [("POOL-OPT-001", 500000.0)]
  
  debug "Yield optimized"
  
  -- Update strategy
  let newStrategy = strategy with targetYield = 0.12
  
  optimizerCid <- submit alice do
    exerciseCmd optimizerCid UpdateStrategy with
      newStrategy
      newTargetYield = 0.12
      newRiskTolerance = Aggressive
  
  debug "Strategy updated"
  
  -- Remove managed pool
  optimizerCid <- submit alice do
    exerciseCmd optimizerCid RemoveManagedPool with
      poolId = "POOL-OPT-001"
  
  debug "Pool removed from optimizer"
  
  debug "=== Yield Optimizer Test Completed ==="



-- MISSING CHOICE TESTS  
