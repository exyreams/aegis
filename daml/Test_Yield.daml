-- | Test Archive choices
testYieldArchives : Script ()
testYieldArchives = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "ArchMgr"
  
  now <- getTime
  
  -- Archive LPToken
  tokenCid <- submit alice do
    createCmd LPToken with
      tokenId = "LP-ARCH"
      poolId = "POOL-ARCH"
      owner = alice
      amount = 1000.0
      poolManager
  
  submit alice do
    archiveCmd tokenCid
  
  -- Archive PerformanceBonus
  bonusCid <- submit poolManager do
    createCmd PerformanceBonus with
      bonusId = "BONUS-ARCH"
      poolId = "POOL-ARCH"
      poolManager
      participants = [(alice, 5000.0)]
      totalBonusPool = 5000.0
      performancePeriodStart = now
      performancePeriodEnd = addRelTime now (days 30)
      distributed = False
  
  submit poolManager do
    archiveCmd bonusCid
  
  -- Archive StakingRewards
  stakingCid <- submitMulti [alice, poolManager] [] do
    createCmd StakingRewards with
      stakingId = "STAKE-ARCH"
      poolId = "POOL-ARCH"
      staker = alice
      poolManager
      stakedLPTokens = 1000.0
      stakingStartDate = now
      lockupPeriod = days 30
      rewardRate = 0.05
      accumulatedRewards = 0.0
  
  submitMulti [alice, poolManager] [] do
    archiveCmd stakingCid
  
  -- Archive YieldOptimizer
  optimizerCid <- submit alice do
    createCmd YieldOptimizer with
      optimizerId = "OPT-ARCH"
      owner = alice
      strategy = YieldStrategy with
        strategyType = DirectLending
        riskTolerance = Moderate
        targetYield = 0.08
        maximumDrawdown = 0.15
        rebalanceThreshold = 0.05
        compoundingEnabled = True
        liquidityReserve = 0.10
      managedPools = []
      totalValue = 0.0
      targetYield = 0.08
      riskTolerance = Moderate
      autoRebalance = True
      lastOptimizationDate = now
  
  submit alice do
    archiveCmd optimizerCid
  
  return ()

