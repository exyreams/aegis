-- | Test creating Performance Bonus template
testCreatePerformanceBonus : Script ()
testCreatePerformanceBonus = do
  parties@Test_Parties{..} <- test_setup
  poolManager <- allocateParty "PoolManager"
  
  debug "=== Testing Performance Bonus Creation ==="
  
  now <- getTime
  
  bonusCid <- submit poolManager do
    createCmd PerformanceBonus with
      bonusId = "BONUS-SIMPLE-001"
      poolId = "POOL-001"
      poolManager
      participants = [(alice, 5000.0), (bob, 3000.0)]
      totalBonusPool = 8000.0
      performancePeriodStart = now
      performancePeriodEnd = addRelTime now (days 30)
      distributed = False
  
  debug "Performance Bonus created successfully"
  
  Some bonus <- queryContractId poolManager bonusCid
  assertMsg "Bonus has correct total" (bonus.totalBonusPool == 8000.0)
  
  debug "=== Performance Bonus Creation Test Completed ==="

