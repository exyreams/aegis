-- | Comprehensive tests for Credit Scoring and Risk Management System
-- Tests credit profiles, risk assessment, and portfolio management

module Test_Credits where

import Daml.Script
import DA.Time
import DA.List (head)
import DA.Optional (isSome)
import Test_Setup
import Types
import Credit
import qualified Aegis
import qualified AuditLog


-- CREDIT PROFILE TESTS
-- | Test creating and updating credit profiles
testCreditProfileCreation : Script ()
testCreditProfileCreation = do
  parties@Test_Parties{..} <- test_setup
  
  debug "=== Testing Credit Profile Creation ==="
  
  now <- getTime
  
  profileCid <- submit alice do
    createCmd CreditProfileContract with
      party = alice
      profileId = "CREDIT-ALICE-001"
      creditScore = 720
      riskRating = A
      totalBorrowed = 0.0
      totalRepaid = 0.0
      currentOutstanding = 0.0
      numberOfLoans = 0
      numberOfDefaults = 0
      numberOfLatePayments = 0
      averageRepaymentTime = 0.0
      longestDelayDays = 0
      defaultHistory = []
      lastUpdated = now
      privacyLevel = RestrictedCredit
  
  debug "Credit profile created with initial score of 720"
  
  Some profile <- queryContractId alice profileCid
  assertMsg "Credit score is valid" (Types.isValidCreditScore profile.creditScore)
  assertMsg "Risk rating is A" (profile.riskRating == A)
  
  debug "=== Credit Profile Creation Test Completed ==="

-- | Test recording loan origination
testLoanOrigination : Script ()
testLoanOrigination = do
  parties@Test_Parties{..} <- test_setup
  
  debug "=== Testing Loan Origination Recording ==="
  
  now <- getTime
  
  profileCid <- submit alice do
    createCmd CreditProfileContract with
      party = alice
      profileId = "CREDIT-ALICE-002"
      creditScore = 700
      riskRating = BBB
      totalBorrowed = 0.0
      totalRepaid = 0.0
      currentOutstanding = 0.0
      numberOfLoans = 0
      numberOfDefaults = 0
      numberOfLatePayments = 0
      averageRepaymentTime = 0.0
      longestDelayDays = 0
      defaultHistory = []
      lastUpdated = now
      privacyLevel = PublicCredit
  
  debug "Initial profile created"
  
  -- Record loan origination
  profileCid <- submit alice do
    exerciseCmd profileCid RecordLoanOrigination with
      loanId = "LOAN-001"
      loanAmount = 50000.0
  
  debug "Loan origination recorded"
  
  Some profile <- queryContractId alice profileCid
  assertMsg "Total borrowed updated" (profile.totalBorrowed == 50000.0)
  assertMsg "Current outstanding updated" (profile.currentOutstanding == 50000.0)
  assertMsg "Number of loans increased" (profile.numberOfLoans == 1)
  
  debug "=== Loan Origination Test Completed ==="

-- | Test recording successful repayment
testSuccessfulRepayment : Script ()
testSuccessfulRepayment = do
  parties@Test_Parties{..} <- test_setup
  
  debug "=== Testing Successful Repayment Recording ==="
  
  now <- getTime
  
  profileCid <- submit alice do
    createCmd CreditProfileContract with
      party = alice
      profileId = "CREDIT-ALICE-003"
      creditScore = 680
      riskRating = BBB
      totalBorrowed = 50000.0
      totalRepaid = 0.0
      currentOutstanding = 50000.0
      numberOfLoans = 1
      numberOfDefaults = 0
      numberOfLatePayments = 0
      averageRepaymentTime = 0.0
      longestDelayDays = 0
      defaultHistory = []
      lastUpdated = now
      privacyLevel = RestrictedCredit
  
  debug "Profile with active loan created"
  
  -- Record on-time repayment
  profileCid <- submit alice do
    exerciseCmd profileCid RecordRepayment with
      loanId = "LOAN-001"
      repaymentAmount = 50000.0
      daysToRepay = 85
      wasOnTime = True
  
  debug "On-time repayment recorded"
  
  Some profile <- queryContractId alice profileCid
  assertMsg "Total repaid updated" (profile.totalRepaid == 50000.0)
  assertMsg "Outstanding reduced" (profile.currentOutstanding == 0.0)
  assertMsg "Credit score improved" (profile.creditScore > 680)
  assertMsg "No late payments" (profile.numberOfLatePayments == 0)
  
  -- Verify audit log was created for credit score update
  auditLogs <- query @AuditLog.BorrowerAuditLog alice
  assertMsg "Audit log should be created for credit score update" (not (null auditLogs))
  debug $ "✓ Audit logs created: " <> show (length auditLogs)
  
  debug "=== Successful Repayment Test Completed ==="

