-- AEGIS INTEGRATION TESTS
-- | Test credit insurance with Aegis platform
testCreditInsuranceWithAegis : Script ()
testCreditInsuranceWithAegis = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "InsuranceLender"
  platform <- allocateParty "AegisPlatform"
  emergencyOp <- allocateParty "EmergencyOp"
  complianceOff <- allocateParty "ComplianceOff"
  
  debug "=== Testing Credit Insurance with Aegis ==="
  
  now <- getTime
  
  -- Initialize Aegis platform with funds
  let initialTreasury = AegisTreasury with
        treasuryBalances = [(Stablecoin "USDC", 5000000.0)]
        reserveRatio = 0.15
        lastAuditDate = now
  
  platformCid <- submitMulti [platform, emergencyOp, complianceOff] [] do
    createCmd Aegis.AegisPlatform with
      platform
      treasury = initialTreasury
      authorizedAssets = [Stablecoin "USDC"]
      platformFeeRate = 0.005
      emergencyOperator = emergencyOp
      complianceOfficer = complianceOff
      totalLoansOriginated = 0.0
      totalFeesCollected = 0.0
      activeLenders = [lender]
      platformStatus = PlatformActive
  
  debug "Aegis platform initialized"
  
  -- Create credit insurance policy
  let endDate = addRelTime now (days 365)
  insuranceCid <- submit lender do
    createCmd CreditInsurance with
      policyId = "INS-LOAN-INS-001"
      lender
      borrower = alice
      loanId = "LOAN-INS-001"
      insuredAmount = 100000.0
      coveragePercentage = 0.8
      premiumRate = 0.02
      policyStartDate = now
      policyEndDate = endDate
      platformCid
      assetType = Stablecoin "USDC"
      status = InsuranceActive
  
  debug "Credit insurance policy created"
  
  Some insurance <- queryContractId lender insuranceCid
  assertMsg "Insurance is active" (insurance.status == InsuranceActive)
  assertMsg "Coverage is 80%" (insurance.coveragePercentage == 0.8)
  
  debug "=== Credit Insurance Test Completed ==="

-- | Test credit guarantee with Aegis platform
testCreditGuaranteeWithAegis : Script ()
testCreditGuaranteeWithAegis = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "GuaranteeLender"
  platform <- allocateParty "AegisPlatform2"
  emergencyOp <- allocateParty "EmergencyOp2"
  complianceOff <- allocateParty "ComplianceOff2"
  
  debug "=== Testing Credit Guarantee with Aegis ==="
  
  now <- getTime
  
  -- Initialize Aegis platform
  let initialTreasury = AegisTreasury with
        treasuryBalances = [(Stablecoin "USDC", 3000000.0)]
        reserveRatio = 0.15
        lastAuditDate = now
  
  platformCid <- submitMulti [platform, emergencyOp, complianceOff] [] do
    createCmd Aegis.AegisPlatform with
      platform
      treasury = initialTreasury
      authorizedAssets = [Stablecoin "USDC"]
      platformFeeRate = 0.005
      emergencyOperator = emergencyOp
      complianceOfficer = complianceOff
      totalLoansOriginated = 0.0
      totalFeesCollected = 0.0
      activeLenders = [lender]
      platformStatus = PlatformActive
  
  debug "Aegis platform initialized"
  
  -- Create credit guarantee
  let validUntil = addRelTime now (days 180)
  guaranteeCid <- submitMulti [alice, lender] [] do
    createCmd CreditGuarantee with
      guaranteeId = show alice <> "-GUARANTEE-" <> show now
      borrower = alice
      lender
      guaranteedAmount = 50000.0
      guaranteePercentage = 0.5
      guaranteeFee = 1000.0
      validFrom = now
      validUntil
      platformCid
      assetType = Stablecoin "USDC"
      status = GuaranteeActive
  
  debug "Credit guarantee created"
  
  Some guarantee <- queryContractId alice guaranteeCid
  assertMsg "Guarantee is active" (guarantee.status == GuaranteeActive)
  assertMsg "Guarantee is 50%" (guarantee.guaranteePercentage == 0.5)
  
  debug "=== Credit Guarantee Test Completed ==="

