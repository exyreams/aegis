    createCmd CreditProfileContract with
      party = alice
      profileId = "CREDIT-REIMBURSE"
      creditScore = 650
      riskRating = BB
      totalBorrowed = 75000.0
      totalRepaid = 0.0
      currentOutstanding = 75000.0
      numberOfLoans = 1
      numberOfDefaults = 0
      numberOfLatePayments = 0
