      concentrationByAssetType = [(Cryptocurrency "ETH", 300000.0)]
      portfolioRiskMetrics = riskMetrics
      lastAssessmentDate = now
  
  submit lender do
    archiveCmd portfolioCid
  
  -- Archive RiskAssessment
  let borrowerProfile = CreditProfile with
        party = alice
        creditScore = 720
        riskRating = A
        totalBorrowed = 100000.0
        totalRepaid = 80000.0
        currentOutstanding = 20000.0
        numberOfLoans = 3
