-- | Run all credit tests
runAllCreditTests : Script ()
runAllCreditTests = do
  testCreditProfileCreation
  testLoanOrigination
  testSuccessfulRepayment
  testLatePayment
  testDefaultRecording
  testDefaultResolution
  testRiskAssessment
  testCreditInquiry
  testUpdatePrivacyLevel
  testPortfolioRisk
  testRiskAssessmentDecisions
