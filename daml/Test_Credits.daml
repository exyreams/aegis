  testArchiveCreditProfile
  testUpdatePortfolioRisk
  testCreditInsuranceWithAegis
  testCreditGuaranteeWithAegis
  -- testDefaultWithPlatformReimbursement  -- TODO: Workflow needs redesign - borrower can't exercise platform choice
  debug "=== All Credit Tests Completed Successfully ==="


-- | Test Archive choices
