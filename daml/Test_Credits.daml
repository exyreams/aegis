-- | Test recording default
testDefaultRecording : Script ()
testDefaultRecording = do
  parties@Test_Parties{..} <- test_setup
  testLender <- allocateParty "TestLender"
  
  debug "=== Testing Default Recording ==="
  
  now <- getTime
  
  profileCid <- submit alice do
    createCmd CreditProfileContract with
      party = alice
      profileId = "CREDIT-ALICE-005"
      creditScore = 650
      riskRating = BB
      totalBorrowed = 40000.0
      totalRepaid = 0.0
      currentOutstanding = 40000.0
      numberOfLoans = 1
      numberOfDefaults = 0
      numberOfLatePayments = 0
      averageRepaymentTime = 0.0
      longestDelayDays = 0
      defaultHistory = []
      lastUpdated = now
      privacyLevel = PrivateCredit
  
  debug "Profile with active loan created"
  
  -- Record default (without platform reimbursement) - requires both borrower and lender
  (profileCid, _) <- submitMulti [alice, testLender] [] do
    exerciseCmd profileCid RecordDefault with
      loanId = "LOAN-003"
      defaultAmount = 40000.0
      defaultDate = now
      lender = testLender
      platformCid = None
      assetType = Stablecoin "USDC"
  
  debug "Default recorded"
  
  Some profile <- queryContractId alice profileCid
  assertMsg "Default counted" (profile.numberOfDefaults == 1)
  assertMsg "Default history updated" (length profile.defaultHistory == 1)
  assertMsg "Credit score significantly reduced" (profile.creditScore < 650)
  
  debug "=== Default Recording Test Completed ==="

-- | Test default resolution
testDefaultResolution : Script ()
testDefaultResolution = do
  parties@Test_Parties{..} <- test_setup
  
  debug "=== Testing Default Resolution ==="
  
  now <- getTime
  
  let defaultEvent = DefaultEvent with
        loanId = "LOAN-004"
        defaultDate = now
        amountInDefault = 25000.0
        resolutionDate = None
        recoveryAmount = None
  
  profileCid <- submit alice do
    createCmd CreditProfileContract with
      party = alice
      profileId = "CREDIT-ALICE-006"
      creditScore = 550
      riskRating = B
      totalBorrowed = 25000.0
      totalRepaid = 0.0
      currentOutstanding = 25000.0
      numberOfLoans = 1
      numberOfDefaults = 1
      numberOfLatePayments = 0
      averageRepaymentTime = 0.0
      longestDelayDays = 0
      defaultHistory = [defaultEvent]
      lastUpdated = now
      privacyLevel = RestrictedCredit
  
  debug "Profile with default created"
  
  -- Record resolution
  let resolutionDate = addRelTime now (days 30)
  profileCid <- submit alice do
    exerciseCmd profileCid RecordDefaultResolution with
      loanId = "LOAN-004"
      resolutionDate
      recoveryAmount = 20000.0
  
  debug "Default resolution recorded"
  
  Some profile <- queryContractId alice profileCid
  let resolvedDefault = head profile.defaultHistory
  assertMsg "Resolution date set" (isSome resolvedDefault.resolutionDate)
  assertMsg "Recovery amount set" (isSome resolvedDefault.recoveryAmount)
  
  debug "=== Default Resolution Test Completed ==="


-- RISK ASSESSMENT TESTS
-- | Test risk assessment creation
testRiskAssessment : Script ()
testRiskAssessment = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "Lender"
  
  debug "=== Testing Risk Assessment ==="
  
  now <- getTime
  
  let borrowerProfile = CreditProfile with
        party = alice
        creditScore = 720
        riskRating = A
        totalBorrowed = 100000.0
        totalRepaid = 80000.0
        currentOutstanding = 20000.0
        numberOfLoans = 3
        numberOfDefaults = 0
        averageRepaymentTime = 88.0
        longestDelayDays = 5
        lastUpdated = now
  
  let collateral = 
        [ CollateralAsset with
            assetId = "ETH-001"
            assetType = Cryptocurrency "ETH"
            quantity = 50.0
            currentValue = 75000.0
            initialValue = 75000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  let riskMetrics = RiskMetrics with
        valueAtRisk = 5000.0
        expectedShortfall = 7500.0
        concentrationRisk = 0.15
        creditRisk = 0.05
        marketRisk = 0.10
        liquidityRisk = 0.08
  
  let baseRate = 0.05
  let adjustedRate = Credit.calculateRiskAdjustedRate borrowerProfile baseRate 50000.0
  let recommendation = Credit.generateApprovalRecommendation borrowerProfile riskMetrics 50000.0
  
  assessmentCid <- submit lender do
    createCmd RiskAssessment with
      assessmentId = "RISK-001"
      borrower = alice
      lender
      loanAmount = 50000.0
      loanDuration = days 90
      collateralAssets = collateral
      borrowerCreditProfile = borrowerProfile
      assessmentDate = now
      riskMetrics
      recommendedRate = baseRate
      riskAdjustedRate = adjustedRate
      approvalRecommendation = recommendation
  
  debug "Risk assessment created"
  
  Some assessment <- queryContractId lender assessmentCid
  assertMsg "Risk-adjusted rate calculated" (assessment.riskAdjustedRate > 0.0)
  assertMsg "Approval recommendation generated" 
    (assessment.approvalRecommendation == StronglyApprove || 
     assessment.approvalRecommendation == Approve)
  
  debug "=== Risk Assessment Test Completed ==="


-- CREDIT INQUIRY TESTS
-- | Test credit inquiry process
testCreditInquiry : Script ()
testCreditInquiry = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "Lender"
  
  debug "=== Testing Credit Inquiry ==="
  
  now <- getTime
  
  -- Lender requests credit information
  inquiryCid <- submit lender do
    createCmd CreditInquiry with
      inquiryId = "INQ-001"
      borrower = alice
      lender
      purpose = "Loan application evaluation"
      requestedAt = now
      status = InquiryPending
      sharedInformation = None
  
  debug "Credit inquiry created"
  
  -- Borrower approves and shares information
  let creditProfile = CreditProfile with
        party = alice
        creditScore = 740
        riskRating = AA
        totalBorrowed = 150000.0
        totalRepaid = 120000.0
        currentOutstanding = 30000.0
        numberOfLoans = 5
        numberOfDefaults = 0
        averageRepaymentTime = 85.0
        longestDelayDays = 3
        lastUpdated = now
  
  inquiryCid <- submit alice do
    exerciseCmd inquiryCid ApproveInquiry with
      creditProfile
  
  debug "Borrower approved inquiry and shared credit information"
  
  Some inquiry <- queryContractId lender inquiryCid
  assertMsg "Inquiry approved" (inquiry.status == InquiryApproved)
  assertMsg "Credit information shared" (isSome inquiry.sharedInformation)
  
  debug "=== Credit Inquiry Test Completed ==="

-- | Test updating privacy level
testUpdatePrivacyLevel : Script ()
testUpdatePrivacyLevel = do
  parties@Test_Parties{..} <- test_setup
  
  debug "=== Testing Update Privacy Level ==="
  
  now <- getTime
  
  profileCid <- submit alice do
    createCmd CreditProfileContract with
      party = alice
      profileId = "CREDIT-ALICE-007"
      creditScore = 720
      riskRating = A
      totalBorrowed = 0.0
      totalRepaid = 0.0
      currentOutstanding = 0.0
      numberOfLoans = 0
      numberOfDefaults = 0
      numberOfLatePayments = 0
      averageRepaymentTime = 0.0
      longestDelayDays = 0
      defaultHistory = []
      lastUpdated = now
      privacyLevel = PublicCredit
  
  debug "Profile created with public privacy"
  
  -- Update to private
  profileCid <- submit alice do
    exerciseCmd profileCid UpdatePrivacyLevel with
      newPrivacyLevel = PrivateCredit
  
  debug "Privacy level updated"
  
  Some profile <- queryContractId alice profileCid
  assertMsg "Privacy level changed" (profile.privacyLevel == PrivateCredit)
  
  debug "=== Update Privacy Level Test Completed ==="

-- | Test portfolio risk management
testPortfolioRisk : Script ()
testPortfolioRisk = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "Lender"
  
  debug "=== Testing Portfolio Risk Management ==="
  
  now <- getTime
  
  let riskMetrics = RiskMetrics with
        valueAtRisk = 10000.0
        expectedShortfall = 15000.0
        concentrationRisk = 0.25
        creditRisk = 0.08
        marketRisk = 0.12
        liquidityRisk = 0.10
  
  portfolioCid <- submit lender do
    createCmd PortfolioRisk with
      portfolioId = "PORT-001"
      lender
      activeLoans = 5
      totalExposure = 500000.0
      averageLTV = 0.65
      concentrationByBorrower = [(alice, 150000.0), (bob, 100000.0)]
      concentrationByAssetType = [(Cryptocurrency "ETH", 300000.0), (Cryptocurrency "BTC", 200000.0)]
      portfolioRiskMetrics = riskMetrics
      lastAssessmentDate = now
  
  debug "Portfolio risk created"
  
  -- Check concentration limits
  result <- submit lender do
    exerciseCmd portfolioCid CheckConcentrationLimits with
      maxBorrowerConcentration = 0.35
      maxAssetTypeConcentration = 0.70
  
  debug "Concentration limits checked"
  
  -- Check result (may or may not be compliant depending on thresholds)
  debug $ "Concentration check result: " <> show result.isCompliant
  
  debug "=== Portfolio Risk Management Test Completed ==="

-- | Test risk assessment acceptance and rejection
testRiskAssessmentDecisions : Script ()
testRiskAssessmentDecisions = do
  parties@Test_Parties{..} <- test_setup
  lender <- allocateParty "Lender"
  
  debug "=== Testing Risk Assessment Decisions ==="
  
  now <- getTime
  
  let borrowerProfile = CreditProfile with
        party = alice
        creditScore = 720
        riskRating = A
        totalBorrowed = 100000.0
        totalRepaid = 80000.0
        currentOutstanding = 20000.0
        numberOfLoans = 3
        numberOfDefaults = 0
        averageRepaymentTime = 88.0
        longestDelayDays = 5
        lastUpdated = now
  
  let collateral = 
        [ CollateralAsset with
            assetId = "ETH-002"
            assetType = Cryptocurrency "ETH"
            quantity = 50.0
            currentValue = 75000.0
            initialValue = 75000.0
            volatilityScore = 0.35
            liquidityRating = HighlyLiquid
            lastValuationTime = now
            valuationSource = "Chainlink"
            haircut = 0.20
        ]
  
  let riskMetrics = RiskMetrics with
        valueAtRisk = 5000.0
        expectedShortfall = 7500.0
        concentrationRisk = 0.15
        creditRisk = 0.05
        marketRisk = 0.10
        liquidityRisk = 0.08
  
  assessmentCid <- submit lender do
    createCmd RiskAssessment with
      assessmentId = "RISK-002"
      borrower = alice
      lender
      loanAmount = 50000.0
      loanDuration = days 90
      collateralAssets = collateral
      borrowerCreditProfile = borrowerProfile
      assessmentDate = now
      riskMetrics
      recommendedRate = 0.05
      riskAdjustedRate = 0.048
      approvalRecommendation = Approve
  
  debug "Risk assessment created"
  
  -- Accept assessment
  submit lender do
    exerciseCmd assessmentCid AcceptAssessment
  
  debug "Assessment accepted"
  
  -- Create another assessment to reject
  assessmentCid2 <- submit lender do
    createCmd RiskAssessment with
      assessmentId = "RISK-003"
      borrower = bob
      lender
      loanAmount = 100000.0
      loanDuration = days 180
      collateralAssets = collateral
      borrowerCreditProfile = borrowerProfile with party = bob, creditScore = 550
      assessmentDate = now
      riskMetrics
      recommendedRate = 0.10
      riskAdjustedRate = 0.15
      approvalRecommendation = Decline
  
  submit lender do
    exerciseCmd assessmentCid2 RejectAssessment with
      rejectionReason = "Credit score too low"
  
  debug "Assessment rejected"
  
  debug "=== Risk Assessment Decisions Test Completed ==="

