# Server Configuration
PORT=8000
NODE_ENV=development

# DAML Configuration
DAML_JSON_API_URL=http://localhost:7575
DAML_LEDGER_ID=sandbox
DAML_APPLICATION_ID=aegis-rfq

# Database Configuration (REQUIRED)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# DAML JWT Configuration (REQUIRED)
DAML_JWT_SECRET=your-32-character-minimum-secret-key
DAML_JWT_ISSUER=aegis-rfq
DAML_JWT_AUDIENCE=daml-ledger
DAML_JWT_EXPIRY=86400

# Better-Auth Configuration (REQUIRED)
BETTER_AUTH_SECRET=your-32-character-minimum-better-auth-secret
BETTER_AUTH_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/aegis.log

# Business Rules
MIN_COLLATERAL_RATIO=1.2
MAX_INTEREST_RATE=0.25
DEFAULT_RFQ_EXPIRY_DAYS=7
SUPPORTED_ASSETS=BTC,ETH,USDC,USDT,DAI

# DAML Template IDs
# WARNING: DO NOT EDIT MANUALLY - These are auto-generated from compiled DAML contracts
# Run: node scripts/extract-template-ids.js after any DAML changes
# Format: <package-id>:<module>:<template>
